---
import { Icon } from "astro-icon/components";
import "./stats-card.css";

interface Props {
  title: string;
  value: string | number;
  icon?: string;
  iconColor?: string;
  iconBg?: string;
}

const { title, value, icon, iconColor = "var(--color-primary)", iconBg = "var(--color-primary-alpha-10)" }: Props = Astro.props;
---

<div class="stat-card">
  {icon && (
    <div class="stat-icon" style={`background: ${iconBg}; color: ${iconColor};`}>
      <Icon name={icon} size={24} />
    </div>
  )}
  <div class="stat-content">
    <h3>{title}</h3>
    <div class="value" data-stat={title.toLowerCase().replace(/\s/g, "-")}>{value}</div>
  </div>
</div>
