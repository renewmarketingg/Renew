---
import Button from "./Button.astro";
import styles from "./styles/readyCta.module.css";

interface Props {
  title?: string;
  subtitle?: string;
  buttonHref?: string;
  buttonLabel?: string;
  buttonIcon?: string;
}

const {
  title = "Pronto para transformar sua presença digital?",
  subtitle = "Entre em contato e vamos discutir como ajudar seu negócio a crescer",
  buttonHref = "#contato",
  buttonLabel = "Falar com Especialista",
  buttonIcon = "lucide:message-circle",
}: Props = Astro.props;
---

<section class={`section ${styles.ctaSection}`}>
  <div class="container">
    <div class={styles.ctaContent}>
      <h2 class={styles.ctaTitle}>{title}</h2>
      <p class={styles.ctaSubtitle}>{subtitle}</p>
      <Button href={buttonHref} variant="tertiary" class={styles.ctaButton} icon={buttonIcon}>
        {buttonLabel}
      </Button>
    </div>
  </div>
</section>
