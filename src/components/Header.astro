---
import styles from "./styles/header.module.css";
import { Icon } from "astro-icon/components";
import Button from "./Button.astro";
import { Image } from "astro:assets";

interface Props {
  variant?: "default" | "admin";
  activePage?: string;
}

const { variant = "default", activePage = "" } = Astro.props;

const isHomePage = Astro.url.pathname === "/" || Astro.url.pathname === "";

const navLinks = [
  { href: isHomePage ? "#home" : "/#home", label: "Início" },
  { href: isHomePage ? "#servicos" : "/#servicos", label: "Serviços" },
  { href: isHomePage ? "#sobre" : "/#sobre", label: "Sobre" },
  { href: isHomePage ? "#contato" : "/#contato", label: "Contato" },
];

const adminNavItems = [
  { href: "/admin", label: "Dashboard", icon: "lucide:layout-dashboard" },
  { href: "/admin/store", label: "Produtos", icon: "lucide:shopping-bag" },
  { href: "/admin/routes", label: "Rotas", icon: "lucide:route" },
  { href: "/admin/logs", label: "Logs", icon: "lucide:file-text" },
  { href: "/admin/settings", label: "Configurações", icon: "lucide:settings" },
];
---

<header
  id={variant === "admin" ? "admin" : "home"}
  class={`${styles.header} ${variant === "admin" ? styles.headerAdmin : ""}`}
>
  <a href="/" class={styles.logo} aria-label="Renew Digital - Página inicial">
    <Image
      width={60}
      height={60}
      loading="eager"
      decoding="async"
      src="/renew.svg"
      alt="Renew Digital"
    />
  </a>

  {
    variant !== "admin" && (
      <nav aria-label="Navegação principal">
        <ul class={`${styles.navMenu} nav-menu`} id="nav-menu">
          {navLinks.map((link) => (
            <li>
              <a href={link.href} class={`${styles.navLink} nav-link`}>
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </nav>
    )
  }

  <div class={`${styles.headerActions} header-actions`}>
    {
      variant === "admin" ? (
        <>
          <nav aria-label="Navegação admin">
            <ul class={styles.adminNavList}>
              {adminNavItems.map((item) => (
                <li>
                  <a
                    href={item.href}
                    class={`${styles.adminNavLink} ${activePage === item.href ? styles.adminNavLinkActive : ""}`}
                  >
                    <Icon size={18} name={item.icon} />
                    <span>{item.label}</span>
                  </a>
                </li>
              ))}
            </ul>
          </nav>
          <a href="/store" target="_blank" class={styles.adminActionBtn} aria-label="Ver loja">
            <Icon size={18} name="lucide:external-link" />
            <span class={styles.adminBtnText}>Ver Loja</span>
          </a>
        </>
      ) : null
    }

    <button class={`${styles.themeToggle} theme-toggle`} aria-label="Alternar tema claro e escuro">
      <Icon size="20" name="lucide:sun" class={styles.iconSun} />
      <Icon size="20" name="lucide:moon" class={styles.iconMoon} />
    </button>

    {
      variant !== "admin" && (
        <Button href="#contato" variant="primary" icon="lucide:message-circle" compact>
          <span>Fale Conosco</span>
        </Button>
      )
    }

    {
      variant === "admin" && (
        <a href="/admin/signout" class={`${styles.adminActionBtn} ${styles.adminLogout}`} aria-label="Sair">
          <Icon size={18} name="lucide:log-out" />
          <span class={styles.adminBtnText}>Sair</span>
        </a>
      )
    }
  </div>

  <button
    class={`${styles.menuToggle} menu-toggle`}
    aria-label="Abrir menu de navegação"
    aria-expanded="false"
    aria-controls="nav-menu"
  >
    <Icon size="20" name="lucide:menu" class={styles.menuIcon} />
    <Icon size="20" name="lucide:x" class={styles.closeIcon} />
  </button>
</header>

<script>
  const themeToggle = document.querySelector(".theme-toggle");
  const html = document.documentElement;

  const savedTheme = localStorage.getItem("theme") || "dark";
  html.setAttribute("data-theme", savedTheme);

  themeToggle?.addEventListener("click", () => {
    const currentTheme = html.getAttribute("data-theme");
    const newTheme = currentTheme === "dark" ? "light" : "dark";
    html.setAttribute("data-theme", newTheme);
    localStorage.setItem("theme", newTheme);
  });

  const menuBtn = document.querySelector(".menu-toggle");
  const navMenu = document.querySelector(".nav-menu");
  const headerActions = document.querySelector(".header-actions");

  menuBtn?.addEventListener("click", () => {
    const isExpanded = menuBtn.getAttribute("aria-expanded") === "true";
    menuBtn.setAttribute("aria-expanded", String(!isExpanded));
    navMenu?.classList.toggle("active");
    headerActions?.classList.toggle("active");
    menuBtn.classList.toggle("active");
  });

  document.querySelectorAll(".nav-link").forEach((link) => {
    link.addEventListener("click", () => {
      navMenu?.classList.remove("active");
      headerActions?.classList.remove("active");
      menuBtn?.classList.remove("active");
      menuBtn?.setAttribute("aria-expanded", "false");
    });
  });
</script>
