---
interface Props {
  analyticsId?: string;
}

const { analyticsId = "" } = Astro.props;
---

{
  analyticsId && (
    <Fragment
      set:html={`
    <script async defer src="https://www.googletagmanager.com/gtag/js?id=${analyticsId}"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', '${analyticsId}');
    </script>
  `}
    />
  )
};
