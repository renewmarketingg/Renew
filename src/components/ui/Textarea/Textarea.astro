---
import { Icon } from 'astro-icon/components';
import styles from './Textarea.module.css';

interface Props {
  name: string;
  label?: string;
  placeholder?: string;
  value?: string;
  required?: boolean;
  disabled?: boolean;
  readonly?: boolean;
  rows?: number;
  maxlength?: number;
  error?: string;
  hint?: string;
  class?: string;
  id?: string;
}

const {
  name,
  label,
  placeholder,
  value,
  required = false,
  disabled = false,
  readonly = false,
  rows = 4,
  maxlength,
  error,
  hint,
  class: className,
  id,
} = Astro.props;

const textareaId = id || `textarea-${name}`;
const hasError = Boolean(error);
---

<div class={`${styles.textareaWrapper} ${className || ''}`}>
  {label && (
    <label for={textareaId} class={styles.label}>
      {label}
      {required && <span class={styles.required}>*</span>}
    </label>
  )}

  <textarea
    name={name}
    id={textareaId}
    placeholder={placeholder}
    required={required}
    disabled={disabled}
    readonly={readonly}
    rows={rows}
    maxlength={maxlength}
    class={`${styles.textarea} ${hasError ? styles.hasError : ''}`}
    aria-invalid={hasError}
    aria-describedby={error ? `${textareaId}-error` : hint ? `${textareaId}-hint` : undefined}
  >{value}</textarea>

  <div class={styles.footer}>
    {error && (
      <p id={`${textareaId}-error`} class={styles.error} role="alert">
        <Icon name="lucide:alert-circle" size={14} />
        {error}
      </p>
    )}
    {!error && hint && (
      <p id={`${textareaId}-hint`} class={styles.hint}>
        {hint}
      </p>
    )}
    {maxlength && (
      <span class={styles.counter}>
        <slot name="counter" />
      </span>
    )}
  </div>
</div>
