---
import { Icon } from "astro-icon/components";
import styles from "./styles/adminStatsCard.module.css";

interface Props {
  title: string;
  subtitle?: string;
  icon?: string;
  iconBg?: string;
  iconColor?: string;
}

const { title, subtitle, icon, iconBg, iconColor } = Astro.props;
---

<div class={styles.statCard}>
  <div
    class={styles.statIcon}
    style={iconBg ? `background: ${iconBg}` : "background: var(--color-primary-alpha-10)"}
  >
    {icon && <Icon name={icon} size={24} style={iconColor ? `color: ${iconColor}` : ""} />}
  </div>
  <div class={styles.statContent}>
    <h3>{title}</h3>
    {subtitle && <div class={styles.subtitle}>{subtitle}</div>}
  </div>
</div>
