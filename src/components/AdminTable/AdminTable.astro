---
import styles from "./styles/adminTable.module.css";
interface Column {
  key: string;
  label: string;
  render?: (value: unknown, row: Record<string, unknown>) => string;
}

interface Props {
  columns: Column[];
  data: Record<string, unknown>[];
  emptyMessage?: string;
}

const { columns, data, emptyMessage = "Nenhum item encontrado" } = Astro.props;
---

<div class={styles.tableWrapper}>
  <table class={styles.table}>
    <thead>
      <tr>
        {columns.map((col) => <th>{col.label}</th>)}
      </tr>
    </thead>
    <tbody id="tableBody">
      {data.length === 0 ? (
        <tr>
          <td colspan={columns.length} class={styles.emptyCell}>
            {emptyMessage}
          </td>
        </tr>
      ) : (
        data.map((row) => (
          <tr data-id={row.id}>
            {columns.map((col) => (
              <td>
                {col.render ? <Fragment set:html={col.render(row[col.key], row)} /> : row[col.key]}
              </td>
            ))}
          </tr>
        ))
      )}
    </tbody>
  </table>
</div>
