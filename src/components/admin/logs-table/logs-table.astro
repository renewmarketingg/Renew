---
import { Icon } from "astro-icon/components";

interface Log {
  id: string;
  timestamp: string;
  level: "info" | "warning" | "error" | "success";
  category: "auth" | "api" | "system";
  message: string;
}

interface Props {
  logs: Log[];
}

const { logs } = Astro.props;

const levelColors: Record<string, string> = {
  info: "#3b82f6",
  warning: "#fbbf24", 
  error: "#ef4444",
  success: "#22c55e",
};

function formatDateTime(isoString: string): string {
  return new Date(isoString).toLocaleString("pt-BR", {
    day: "2-digit",
    month: "2-digit",
    year: "numeric",
    hour: "2-digit",
    minute: "2-digit",
  });
}
---

<div class="table-wrapper">
  <table class="table">
    <thead>
      <tr>
        <th>Timestamp</th>
        <th>Nível</th>
        <th>Categoria</th>
        <th>Mensagem</th>
        <th></th>
      </tr>
    </thead>
    <tbody id="logsTableBody">
      {logs.length === 0 ? (
        <tr>
          <td colspan="5" class="text-center p-8">Nenhum log</td>
        </tr>
      ) : (
        logs.slice(0, 100).map((l) => (
          <tr data-id={l.id}>
            <td class="text-sm">{formatDateTime(l.timestamp)}</td>
            <td>
              <span class="badge" style={`background:${levelColors[l.level]}20;color:${levelColors[l.level]}`}>
                {l.level}
              </span>
            </td>
            <td>{l.category}</td>
            <td>{l.message}</td>
            <td>
              <button class="action-btn detail-btn" data-id={l.id} aria-label="Ver detalhes">
                <Icon name="lucide:eye" size={16} />
              </button>
            </td>
          </tr>
        ))
      )}
    </tbody>
  </table>
</div>

<script>
  document.querySelectorAll(".detail-btn").forEach((btn) => {
    btn.addEventListener("click", () => {
      const event = new CustomEvent("log-detail", { detail: btn.getAttribute("data-id") });
      document.dispatchEvent(event);
    });
  });
</script>
