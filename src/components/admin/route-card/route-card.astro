---
import { Icon } from "astro-icon/components";

interface Route {
  id: string;
  label: string;
  path: string;
  description?: string;
  category: string;
  dynamic: boolean;
  dynamicParams?: string;
  active: boolean;
}

interface Props {
  routes: Route[];
}

const { routes } = Astro.props;
---

<div class="card-grid" id="routesGrid">
  {routes.length === 0 ? (
    <div class="empty-state">
      <Icon name="lucide:route" size={48} />
      <h3>Nenhuma rota</h3>
    </div>
  ) : (
    routes.map((r) => (
      <div class={`route-card ${r.active ? "" : "inactive"}`}>
        <div class="route-card-header">
          <span class={`badge badge-${r.category.toLowerCase()}`}>{r.category}</span>
          {r.dynamic && <span class="badge badge-dynamic">Dinâmica</span>}
          <div class="route-actions">
            <button class="action-btn edit-btn" data-id={r.id} aria-label="Editar">
              <Icon name="lucide:pencil" size={16} />
            </button>
            <button class="action-btn toggle-btn" data-id={r.id} aria-label={r.active ? "Desativar" : "Ativar"}>
              <Icon name={r.active ? "lucide:toggle-right" : "lucide:toggle-left"} size={16} />
            </button>
            <button class="action-btn delete-btn" data-id={r.id} data-name={r.label} aria-label="Excluir">
              <Icon name="lucide:trash-2" size={16} />
            </button>
          </div>
        </div>
        <div class="route-card-body">
          <h4 class="font-bold mb-2">{r.label}</h4>
          <code class="route-path">{r.path}</code>
          {r.description && <p class="text-sm text-gray-400 mt-2">{r.description}</p>}
        </div>
      </div>
    ))
  )}
</div>

<script>
  document.querySelectorAll(".edit-btn").forEach((btn) => {
    btn.addEventListener("click", () => {
      const event = new CustomEvent("route-edit", { detail: btn.getAttribute("data-id") });
      document.dispatchEvent(event);
    });
  });

  document.querySelectorAll(".toggle-btn").forEach((btn) => {
    btn.addEventListener("click", () => {
      const event = new CustomEvent("route-toggle", { detail: btn.getAttribute("data-id") });
      document.dispatchEvent(event);
    });
  });

  document.querySelectorAll(".delete-btn").forEach((btn) => {
    btn.addEventListener("click", () => {
      const event = new CustomEvent("route-delete", { 
        detail: { id: btn.getAttribute("data-id"), name: btn.getAttribute("data-name") } 
      });
      document.dispatchEvent(event);
    });
  });
</script>
