---
interface Props {
  title: string;
  subtitle?: string;
}

const { title, subtitle }: Props = Astro.props;
---

<div class="page-header">
  <div class="page-header-content">
    <h1>{title}</h1>
    {subtitle && <p class="page-subtitle">{subtitle}</p>}
  </div>
  <div class="page-header-actions">
    <slot />
  </div>
</div>
