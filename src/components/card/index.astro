---
import "./index.css";

interface Props {
  variant?: "default" | "gradient";
  size?: "sm" | "md" | "lg";
  hoverable?: boolean;
}

const { variant = "default", size = "md", hoverable = true } = Astro.props;
---

<div class:list={["card", `card-${size}`, variant, { hoverable }]}>
  <slot />
</div>
