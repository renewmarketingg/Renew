---
import { Icon } from "astro-icon/components";
import quickLinks from "../../constants/quickLinks";
import services from "../../constants/services";
import socialLinks from "../../constants/socialLinks";
import List from "../list/list.astro";
import "./footer.css";

const currentYear = new Date().getFullYear();

const contactItems = [
  { icon: "lucide:mail", label: "contato@renewdigital.com.br" },
  { icon: "lucide:phone", label: "(43) 99828-0078" },
  { icon: "lucide:map-pin", label: "Manoel Ribas, PR" },
];
---

<footer class="footer" id="contato">
  <div class="container">
    <div class="footer-content">
      <div class="footer-brand">
        <a href="/" class="footer-logo">
          <span class="logo-text">Renew</span>
          <span class="logo-accent">Digital</span>
        </a>
        <p class="footer-description">Transformamos ideias em resultados digitais.</p>
        <div class="social-links">
          {socialLinks.map((s) => (
            <a target="_blank" href={s.href} class="social-link" aria-label={s.label}>
              <Icon name={s.icon} />
            </a>
          ))}
        </div>
      </div>

      <div class="footer-links">
        <h4>Links Rápidos</h4>
        <List items={quickLinks.map(l => ({ label: l.label, href: l.href }))} variant="links" />
      </div>

      <div class="footer-links">
        <h4>Serviços</h4>
        <List items={services.slice(0, 4).map(s => ({ label: s.title, href: "#servicos" }))} variant="links" />
      </div>

      <div class="footer-contact">
        <h4>Contato</h4>
        <List items={contactItems} variant="contact" />
      </div>
    </div>

    <div class="footer-bottom">
      <p>&copy; {currentYear} Renew Digital. Todos os direitos reservados.</p>
    </div>
  </div>
</footer>
