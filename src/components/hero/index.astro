---
import { Icon } from "astro-icon/components";
import services from "../../constants/services";
import Button from "../button/index.astro";
import "./index.css";

const heroServices = services.slice(0, 4);
---

<section class="hero">
  <div class="hero-bg"></div>
  <div class="hero-particles"></div>

  <div class="container hero-container">
    <div class="hero-content">
      <span class="hero-badge">
        <Icon name="lucide:sparkles" />
        Transformação Digital
      </span>

      <h1 class="hero-title">
        Eleve sua marca para o
        <span class="highlight">mundo digital</span>
      </h1>

      <p class="hero-description">
        Somos especializados em criar presenças online impactantes.
      </p>

      <div class="hero-actions">
        <Button
          href="#servicos"
          variant="primary"
          iconPosition="right"
          icon="lucide:arrow-right">Ver Serviços</Button
        >
        <Button href="#contato" variant="secondary" icon="lucide:message-circle"
          >Falar com Especialista</Button
        >
      </div>

      <div class="hero-stats">
        <div class="stat">
          <span class="stat-number">50+</span>
          <span class="stat-label">Projetos</span>
        </div>
        <div class="stat">
          <span class="stat-number">98%</span>
          <span class="stat-label">Satisfeitos</span>
        </div>
        <div class="stat">
          <span class="stat-number">5+</span>
          <span class="stat-label">Anos</span>
        </div>
      </div>
    </div>

    <div class="hero-grid-container">
      <div class="floating-shapes">
        <div class="shape shape-1"></div>
        <div class="shape shape-2"></div>
        <div class="shape shape-3"></div>
      </div>

      <div class="interactive-grid">
        {
          heroServices.map((s, i) => (
            <div class="grid-card" style={`--i: ${i}`}>
              <div class="shine" />
              <div class="card-inner">
                <Icon name={s.icon} class="grid-icon" />
                <div class="grid-text">
                  <h4>{s.title}</h4>
                  <p>{s.description}</p>
                </div>
              </div>
            </div>
          ))
        }
      </div>

      <div class="grid-reflection"></div>
    </div>
  </div>
</section>
