---
import styles from "./styles/card.module.css";

interface Props {
  variant?: "default" | "gradient";
  size?: "sm" | "md" | "lg";
  hoverable?: boolean;
  class?: string;
}

const { variant = "default", size = "md", hoverable = true, class: className } = Astro.props;

const sizeClass = size === "sm" ? styles.cardSm : size === "lg" ? styles.cardLg : styles.cardMd;
const variantClass = variant === "gradient" ? styles.cardGradient : "";
const hoverClass = hoverable ? styles.cardHoverable : "";
---

<div
  class={`${styles.card} ${sizeClass} ${variantClass} ${hoverClass} ${className || ""}`}
>
  <slot />
</div>
