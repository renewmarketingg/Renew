---
import { Icon } from "astro-icon/components";
import quickLinks from "../constants/quickLinks";
import services from "../constants/services";
import socialLinks from "../constants/socialLinks";
import List from "./List.astro";
import styles from "./styles/footer.module.css";

const currentYear = new Date().getFullYear();

const contactItems = [
  { icon: "lucide:mail", label: "contato@renewdigital.com.br" },
  { icon: "lucide:phone", label: "(43) 99828-0078" },
  { icon: "lucide:map-pin", label: "Manoel Ribas, PR" },
];
---

<footer class={styles.footer} id="contato">
  <div class="container">
    <div class={styles.footerContent}>
      <div class={styles.footerBrand}>
        <a href="/" class={styles.footerLogo}>
          <span class={styles.logoText}>Renew</span>
          <span class={styles.logoAccent}>Digital</span>
        </a>
        <p class={styles.footerDescription}>Transformamos ideias em resultados digitais.</p>
        <div class={styles.socialLinks}>
          {socialLinks.map((s) => (
            <a target="_blank" href={s.href} class={styles.socialLink} aria-label={s.label}>
              <Icon name={s.icon} />
            </a>
          ))}
        </div>
      </div>

      <div class={styles.footerLinks}>
        <h4>Links Rápidos</h4>
        <List items={quickLinks.map(l => ({ label: l.label, href: l.href }))} variant="links" />
      </div>

      <div class={styles.footerLinks}>
        <h4>Serviços</h4>
        <List items={services.slice(0, 4).map(s => ({ label: s.title, href: "#servicos" }))} variant="links" />
      </div>

      <div class={styles.footerContact}>
        <h4>Contato</h4>
        <List items={contactItems} variant="contact" />
      </div>
    </div>

    <div class={styles.footerBottom}>
      <p>&copy; {currentYear} Renew Digital. Todos os direitos reservados.</p>
    </div>
  </div>
</footer>
