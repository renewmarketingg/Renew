---
import './header.css';
import { Icon } from 'astro-icon/components';
import Button from '../button/button.astro';
import { Image } from 'astro:assets';

interface Props {
  variant?: 'default' | 'admin';
  activePage?: string;
}

const { variant = 'default', activePage = '' } = Astro.props;

const isHomePage = Astro.url.pathname === '/' || Astro.url.pathname === '';

const navLinks = [
  { href: isHomePage ? '#home' : '/#home', label: 'Início' },
  { href: isHomePage ? '#servicos' : '/#servicos', label: 'Serviços' },
  { href: isHomePage ? '#sobre' : '/#sobre', label: 'Sobre' },
  { href: isHomePage ? '#contato' : '/#contato', label: 'Contato' },
];

const adminNavItems = [
  { href: '/admin', label: 'Dashboard', icon: 'lucide:layout-dashboard' },
  { href: '/admin/store', label: 'Produtos', icon: 'lucide:shopping-bag' },
  { href: '/admin/routes', label: 'Rotas', icon: 'lucide:route' },
  { href: '/admin/logs', label: 'Logs', icon: 'lucide:file-text' },
  { href: '/admin/settings', label: 'Configurações', icon: 'lucide:settings' },
];
---

<header
  id={variant === 'admin' ? 'admin' : 'home'}
  class:list={['header', variant === 'admin' && 'header-admin']}
>
  <a href="/" class="logo" aria-label="Renew Digital - Página inicial">
    <Image
      width={60}
      height={60}
      loading="eager"
      decoding="async"
      src="/renew.svg"
      alt="Renew Digital"
    />
  </a>

  {
    variant !== 'admin' && (
      <nav class="nav" aria-label="Navegação principal">
        <ul class="nav-menu" id="nav-menu">
          {navLinks.map((link) => (
            <li>
              <a href={link.href} class="nav-link">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </nav>
    )
  }

  <div class="header-actions">
    {
      variant === 'admin' ? (
        <>
          <nav class="admin-nav" aria-label="Navegação admin">
            <ul class="admin-nav-list">
              {adminNavItems.map((item) => (
                <li>
                  <a
                    href={item.href}
                    class:list={['admin-nav-link', { active: activePage === item.href }]}
                  >
                    <Icon size={18} name={item.icon} />
                    <span>{item.label}</span>
                  </a>
                </li>
              ))}
            </ul>
          </nav>
          <a href="/store" target="_blank" class="admin-action-btn" aria-label="Ver loja">
            <Icon size={18} name="lucide:external-link" />
            <span class="admin-btn-text">Ver Loja</span>
          </a>
        </>
      ) : null
    }

    <button class="theme-toggle" aria-label="Alternar tema claro e escuro">
      <Icon size="20" name="lucide:sun" class="icon-sun" />
      <Icon size="20" name="lucide:moon" class="icon-moon" />
    </button>

    {
      variant !== 'admin' && (
        <Button href="#contato" variant="primary" icon="lucide:message-circle">
          <span class="btn-text">Fale Conosco</span>
        </Button>
      )
    }

    {
      variant === 'admin' && (
        <a href="/admin/signout" class="admin-action-btn admin-logout" aria-label="Sair">
          <Icon size={18} name="lucide:log-out" />
          <span class="admin-btn-text">Sair</span>
        </a>
      )
    }
  </div>

  <button
    class="menu-toggle"
    aria-label="Abrir menu de navegação"
    aria-expanded="false"
    aria-controls="nav-menu"
  >
    <Icon size="20" name="lucide:menu" class="menu-icon" />
    <Icon size="20" name="lucide:x" class="close-icon" />
  </button>
</header>

<script>
  const themeToggle = document.querySelector('.theme-toggle');
  const html = document.documentElement;

  const savedTheme = localStorage.getItem('theme') || 'dark';
  html.setAttribute('data-theme', savedTheme);

  themeToggle?.addEventListener('click', () => {
    const currentTheme = html.getAttribute('data-theme');
    const newTheme = currentTheme === 'dark' ? 'light' : 'dark';
    html.setAttribute('data-theme', newTheme);
    localStorage.setItem('theme', newTheme);
  });

  const menuBtn = document.querySelector('.menu-toggle');
  const navMenu = document.querySelector('.nav-menu');
  const headerActions = document.querySelector('.header-actions');

  menuBtn?.addEventListener('click', () => {
    const isExpanded = menuBtn.getAttribute('aria-expanded') === 'true';
    menuBtn.setAttribute('aria-expanded', String(!isExpanded));
    navMenu?.classList.toggle('active');
    headerActions?.classList.toggle('active');
    menuBtn.classList.toggle('active');
  });

  document.querySelectorAll('.nav-link').forEach((link) => {
    link.addEventListener('click', () => {
      navMenu?.classList.remove('active');
      headerActions?.classList.remove('active');
      menuBtn?.classList.remove('active');
      menuBtn?.setAttribute('aria-expanded', 'false');
    });
  });
</script>
