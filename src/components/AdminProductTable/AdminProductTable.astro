---
import { Icon } from 'astro-icon/components';
import styles from "./styles/adminProductTable.module.css";

interface Product {
  id: string;
  name: string;
  description: string;
  price: number;
  originalPrice?: number;
  category: string;
  rating: number;
  reviews: number;
  image: string;
  affiliateLink: string;
  featured: boolean;
}

interface Props {
  products: Product[];
  onEdit: (id: string) => void;
  onDelete: (id: string, name: string) => void;
}

const { products }: Props = Astro.props;

function formatPrice(value: number): string {
  return new Intl.NumberFormat('pt-BR', {
    style: 'currency',
    currency: 'BRL',
  }).format(value);
}
---

<div class="table-wrapper">
  <table class="table">
    <thead>
      <tr>
        <th>Produto</th>
        <th>Categoria</th>
        <th>Preço</th>
        <th>Status</th>
        <th></th>
      </tr>
    </thead>
    <tbody id="tableBody">
      {
        products.length === 0 ? (
          <tr>
            <td colspan="5" class="text-center p-8">
              Nenhum produto
            </td>
          </tr>
        ) : (
          products.map((p) => (
            <tr data-id={p.id}>
              <td>
                <div class={styles.productCell}>
                  <img src={p.image} alt="" class={styles.productThumb} loading="lazy" />
                  <div class={styles.productInfo}>
                    <h4>{p.name}</h4>
                    <span>{p.reviews?.toLocaleString() || 0} avaliações</span>
                  </div>
                </div>
              </td>
              <td>{p.category}</td>
              <td>
                {formatPrice(p.price)}
                {p.originalPrice && (
                  <span class="text-sm text-gray-400 line-through ml-2">
                    {formatPrice(p.originalPrice)}
                  </span>
                )}
              </td>
              <td>
                <span class={`badge ${p.featured ? 'badge-featured' : 'badge-active'}`}>
                  {p.featured ? 'Destaque' : 'Ativo'}
                </span>
              </td>
              <td>
                <div class="flex gap-1">
                  <button class="action-btn edit-btn" data-id={p.id} aria-label="Editar">
                    <Icon name="lucide:pencil" size={16} />
                  </button>
                  <button
                    class="action-btn delete-btn"
                    data-id={p.id}
                    data-name={p.name}
                    aria-label="Excluir"
                  >
                    <Icon name="lucide:trash-2" size={16} />
                  </button>
                </div>
              </td>
            </tr>
          ))
        )
      }
    </tbody>
  </table>
</div>

<script>
  document.querySelectorAll('.edit-btn').forEach((btn) => {
    btn.addEventListener('click', () => {
      const event = new CustomEvent('product-edit', { detail: btn.getAttribute('data-id') });
      document.dispatchEvent(event);
    });
  });

  document.querySelectorAll('.delete-btn').forEach((btn) => {
    btn.addEventListener('click', () => {
      const event = new CustomEvent('product-delete', {
        detail: { id: btn.getAttribute('data-id'), name: btn.getAttribute('data-name') },
      });
      document.dispatchEvent(event);
    });
  });
</script>
