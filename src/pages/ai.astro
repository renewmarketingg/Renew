---
import Button from '@components/ui/Button/Button.astro';
import { Icon } from 'astro-icon/components';
import Layout from '@/layouts/Layout.astro';
import '@/styles/ai.css';
import '@/styles/global.css';
---

<Layout
  title="IA - Renew Digital"
  description="Assistente de IA para ajudar em suas tarefas"
  theme="dark"
  hideHeaderFooter
>
  <div class="ai-container">
    <aside class="ai-sidebar">
      <div class="ai-sidebar-header">
        <Button variant="primary" icon="lucide:plus" class="new-chat-btn" id="newChatBtn">
          Novo Chat
        </Button>
      </div>

      <div class="ai-sidebar-section">
        <div class="ai-sidebar-label">
          <Icon name="lucide:folder" size={14} />
          <span>Projetos</span>
        </div>
        <button class="ai-sidebar-item" id="connectProjectBtn">
          <Icon name="lucide:hard-drive" size={16} />
          <span>Conectar projeto</span>
        </button>
        <button class="ai-sidebar-item" id="createProjectBtn">
          <Icon name="lucide:folder-plus" size={16} />
          <span>Criar projeto</span>
        </button>
      </div>

      <div class="ai-sidebar-chats" id="chatList">
        <div class="ai-sidebar-label">
          <Icon name="lucide:message-square" size={14} />
          <span>Conversas</span>
        </div>
      </div>
    </aside>

    <main class="ai-main">
      <header class="ai-header">
        <div class="ai-model-selector" id="modelSelector">
          <button class="ai-model-btn" id="modelBtn">
            <Icon name="lucide:sparkles" size={18} />
            <span id="currentModel">Selecionar Modelo</span>
            <Icon name="lucide:chevron-down" size={16} />
          </button>
          <div class="ai-model-dropdown" id="modelDropdown">
            <div class="ai-model-group">
              <span class="ai-model-group-label">OpenAI</span>
              <button class="ai-model-option" data-model="gpt-4o" data-provider="openai">
                <Icon name="lucide:sparkles" size={16} />
                <div class="ai-model-info">
                  <span class="ai-model-name">GPT-4o</span>
                  <span class="ai-model-desc">Mais capaz e rápido</span>
                </div>
              </button>
              <button class="ai-model-option" data-model="gpt-4o-mini" data-provider="openai">
                <Icon name="lucide:sparkles" size={16} />
                <div class="ai-model-info">
                  <span class="ai-model-name">GPT-4o Mini</span>
                  <span class="ai-model-desc">Rápido e econômico</span>
                </div>
              </button>
              <button class="ai-model-option" data-model="gpt-4-turbo" data-provider="openai">
                <Icon name="lucide:sparkles" size={16} />
                <div class="ai-model-info">
                  <span class="ai-model-name">GPT-4 Turbo</span>
                  <span class="ai-model-desc">Alto desempenho</span>
                </div>
              </button>
            </div>
            <div class="ai-model-group">
              <span class="ai-model-group-label">Anthropic</span>
              <button class="ai-model-option" data-model="claude-3-5-sonnet-20241022" data-provider="anthropic">
                <Icon name="lucide:bot" size={16} />
                <div class="ai-model-info">
                  <span class="ai-model-name">Claude 3.5 Sonnet</span>
                  <span class="ai-model-desc">Análise profunda e código</span>
                </div>
              </button>
              <button class="ai-model-option" data-model="claude-3-5-haiku-20241022" data-provider="anthropic">
                <Icon name="lucide:bot" size={16} />
                <div class="ai-model-info">
                  <span class="ai-model-name">Claude 3.5 Haiku</span>
                  <span class="ai-model-desc">Rápido e preciso</span>
                </div>
              </button>
            </div>
            <div class="ai-model-group">
              <span class="ai-model-group-label">Google</span>
              <button class="ai-model-option" data-model="gemini-1.5-pro" data-provider="google">
                <Icon name="lucide:gem" size={16} />
                <div class="ai-model-info">
                  <span class="ai-model-name">Gemini 1.5 Pro</span>
                  <span class="ai-model-desc">Contexto longo (2M tokens)</span>
                </div>
              </button>
              <button class="ai-model-option" data-model="gemini-1.5-flash" data-provider="google">
                <Icon name="lucide:gem" size={16} />
                <div class="ai-model-info">
                  <span class="ai-model-name">Gemini 1.5 Flash</span>
                  <span class="ai-model-desc">Rápido e eficiente</span>
                </div>
              </button>
            </div>
            <div class="ai-model-group">
              <span class="ai-model-group-label">Mistral</span>
              <button class="ai-model-option" data-model="mistral-large-latest" data-provider="mistral">
                <Icon name="lucide:wind" size={16} />
                <div class="ai-model-info">
                  <span class="ai-model-name">Mistral Large</span>
                  <span class="ai-model-desc">Alto desempenho</span>
                </div>
              </button>
              <button class="ai-model-option" data-model="mistral-small-latest" data-provider="mistral">
                <Icon name="lucide:wind" size="16" />
                <div class="ai-model-info">
                  <span class="ai-model-name">Mistral Small</span>
                  <span class="ai-model-desc">Rápido e econômico</span>
                </div>
              </button>
            </div>
            <div class="ai-model-group">
              <span class="ai-model-group-label">Groq</span>
              <button class="ai-model-option" data-model="llama-3.1-70b-versatile" data-provider="groq">
                <Icon name="lucide:bird" size="16" />
                <div class="ai-model-info">
                  <span class="ai-model-name">Llama 3.1 70B</span>
                  <span class="ai-model-desc">Versátil e rápido</span>
                </div>
              </button>
              <button class="ai-model-option" data-model="mixtral-8x7b-32768" data-provider="groq">
                <Icon name="lucide:bird" size="16" />
                <div class="ai-model-info">
                  <span class="ai-model-name">Mixtral 8x7B</span>
                  <span class="ai-model-desc">Alta qualidade</span>
                </div>
              </button>
            </div>
            <div class="ai-model-group">
              <span class="ai-model-group-label">Cohere</span>
              <button class="ai-model-option" data-model="command-r-plus" data-provider="cohere">
                <Icon name="lucide:cpu" size="16" />
                <div class="ai-model-info">
                  <span class="ai-model-name">Command R+</span>
                  <span class="ai-model-desc">RAG otimizado</span>
                </div>
              </button>
              <button class="ai-model-option" data-model="command-r" data-provider="cohere">
                <Icon name="lucide:cpu" size="16" />
                <div class="ai-model-info">
                  <span class="ai-model-name">Command R</span>
                  <span class="ai-model-desc">Eficiente</span>
                </div>
              </button>
            </div>
          </div>
        </div>

        <div class="ai-header-center">
          <h1 class="ai-title">Assistente IA</h1>
        </div>

        <div class="ai-header-right">
          <button class="ai-settings-btn" id="settingsBtn" aria-label="Configurações">
            <Icon name="lucide:settings" size={20} />
          </button>
          <button class="theme-toggle ai-theme-toggle" id="themeToggleBtn" aria-label="Alternar tema">
            <Icon name="lucide:sun" size={20} class="icon-sun" />
            <Icon name="lucide:moon" size={20} class="icon-moon" />
          </button>
          <button class="ai-clear-btn" id="clearChatBtn" aria-label="Limpar conversa">
            <Icon name="lucide:trash-2" size={20} />
          </button>
        </div>
      </header>

      <div class="ai-chat-area" id="chatArea">
        <div class="ai-welcome" id="welcomeScreen">
          <div class="ai-welcome-icon">
            <Icon name="lucide:sparkles" size={48} />
          </div>
          <h2>Como posso ajudar hoje?</h2>
          <p>Envie uma mensagem ou escolha uma ação abaixo</p>
          <div class="ai-quick-actions">
            <button class="ai-quick-action" data-prompt="Crie uma imagem de">
              <Icon name="lucide:image-plus" size={20} />
              <span>Criar imagem</span>
            </button>
            <button class="ai-quick-action" data-prompt="Analise este código:">
              <Icon name="lucide:code" size={20} />
              <span>Analisar código</span>
            </button>
            <button class="ai-quick-action" data-prompt="Resuma este texto:">
              <Icon name="lucide:file-text" size={20} />
              <span>Resumir texto</span>
            </button>
            <button class="ai-quick-action" data-prompt="Traduza para o inglês:">
              <Icon name="lucide:languages" size={20} />
              <span>Traduzir</span>
            </button>
          </div>
        </div>
        <div class="ai-messages" id="messagesContainer"></div>
      </div>

      <div class="ai-input-area">
        <div class="ai-input-container">
          <button class="ai-input-action" id="attachBtn" aria-label="Anexar imagem">
            <Icon name="lucide:paperclip" size={20} />
          </button>

          <div class="ai-input-wrapper">
            <textarea
              id="chatInput"
              placeholder="Digite sua mensagem..."
              rows="1"
              autocomplete="off"></textarea>
            <div class="ai-input-tools">
              <button class="ai-tool-btn" id="voiceBtn" aria-label="Usar voz">
                <Icon name="lucide:mic" size={18} />
              </button>
              <button class="ai-tool-btn" id="imageGenBtn" aria-label="Gerar imagem">
                <Icon name="lucide:image-plus" size={18} />
              </button>
            </div>
          </div>

          <button class="ai-send-btn" id="sendBtn" aria-label="Enviar mensagem">
            <Icon name="lucide:send" size={20} />
          </button>
        </div>
        <p class="ai-input-hint">IA pode cometer erros. Verifique informações importantes.</p>
      </div>
    </main>
  </div>

  <input type="file" id="fileInput" accept="image/*" hidden />
  <input type="file" id="folderInput" hidden />

  <div class="modal-overlay ai-projects-modal" id="projectModal">
    <div class="modal">
      <div class="modal-header">
        <h2>Projetos Conectados</h2>
        <button class="modal-close" id="closeProjectModal" aria-label="Fechar">&times;</button>
      </div>
      <div class="modal-body">
        <div class="ai-project-list" id="projectList"></div>
        <div class="ai-connect-folder">
          <Icon name="lucide:folder-open" size={48} />
          <p>Conecte uma pasta do seu computador para que a IA possa analisar seus arquivos</p>
          <Button
            variant="secondary"
            icon="lucide:folder-plus"
            class="ai-connect-btn"
            id="connectFolderBtn"
          >
            Selecionar Pasta
          </Button>
        </div>
      </div>
    </div>
  </div>

  <div class="modal-overlay ai-projects-modal" id="createProjectModal">
    <div class="modal">
      <div class="modal-header">
        <h2>Criar Novo Projeto</h2>
        <button class="modal-close" id="closeCreateModal" aria-label="Fechar">&times;</button>
      </div>
      <div class="modal-body">
        <div class="form-group">
          <label for="newProjectName">Nome do Projeto</label>
          <input type="text" id="newProjectName" placeholder="Meu Projeto" />
        </div>
        <div class="form-group">
          <label for="newProjectDesc">Descrição (opcional)</label>
          <textarea id="newProjectDesc" placeholder="Descrição do projeto..." rows="3"></textarea>
        </div>
        <Button variant="primary" id="saveProjectBtn" class="btn-full">
          <Icon name="lucide:plus" size={18} />
          Criar Projeto
        </Button>
      </div>
    </div>
  </div>

  <!-- Settings Modal -->
  <div class="modal-overlay ai-settings-modal" id="settingsModal">
    <div class="modal">
      <div class="modal-header">
        <h2>Configurações</h2>
        <button class="modal-close" id="closeSettingsModal" aria-label="Fechar">&times;</button>
      </div>
      <div class="modal-body">
        <div class="form-group">
          <label>Provedores de IA</label>
          <div class="ai-providers-status" id="providersStatus">
            <div class="ai-provider-item" data-provider="openai">
              <span class="provider-status-dot"></span>
              <span class="provider-name">OpenAI</span>
              <a href="https://platform.openai.com/api-keys" target="_blank" rel="noopener" class="provider-link">Obter chave</a>
            </div>
            <div class="ai-provider-item" data-provider="anthropic">
              <span class="provider-status-dot"></span>
              <span class="provider-name">Anthropic</span>
              <a href="https://console.anthropic.com/" target="_blank" rel="noopener" class="provider-link">Obter chave</a>
            </div>
            <div class="ai-provider-item" data-provider="google">
              <span class="provider-status-dot"></span>
              <span class="provider-name">Google</span>
              <a href="https://aistudio.google.com/app/apikey" target="_blank" rel="noopener" class="provider-link">Obter chave</a>
            </div>
            <div class="ai-provider-item" data-provider="mistral">
              <span class="provider-status-dot"></span>
              <span class="provider-name">Mistral</span>
              <a href="https://console.mistral.ai/api-keys/" target="_blank" rel="noopener" class="provider-link">Obter chave</a>
            </div>
            <div class="ai-provider-item" data-provider="groq">
              <span class="provider-status-dot"></span>
              <span class="provider-name">Groq</span>
              <a href="https://console.groq.com/keys" target="_blank" rel="noopener" class="provider-link">Obter chave</a>
            </div>
            <div class="ai-provider-item" data-provider="cohere">
              <span class="provider-status-dot"></span>
              <span class="provider-name">Cohere</span>
              <a href="https://dashboard.cohere.com/api-keys" target="_blank" rel="noopener" class="provider-link">Obter chave</a>
            </div>
          </div>
          <p class="form-hint">Configure as variáveis de ambiente para ativar os provedores</p>
        </div>
        <div class="form-group">
          <label for="defaultModel">Modelo Padrão</label>
          <select id="defaultModel">
            <optgroup label="OpenAI">
              <option value="gpt-4o">GPT-4o</option>
              <option value="gpt-4o-mini">GPT-4o Mini</option>
              <option value="gpt-4-turbo">GPT-4 Turbo</option>
            </optgroup>
            <optgroup label="Anthropic">
              <option value="claude-3-5-sonnet-20241022">Claude 3.5 Sonnet</option>
              <option value="claude-3-5-haiku-20241022">Claude 3.5 Haiku</option>
            </optgroup>
            <optgroup label="Google">
              <option value="gemini-1.5-pro">Gemini 1.5 Pro</option>
              <option value="gemini-1.5-flash">Gemini 1.5 Flash</option>
            </optgroup>
            <optgroup label="Mistral">
              <option value="mistral-large-latest">Mistral Large</option>
              <option value="mistral-small-latest">Mistral Small</option>
            </optgroup>
            <optgroup label="Groq">
              <option value="llama-3.1-70b-versatile">Llama 3.1 70B</option>
              <option value="mixtral-8x7b-32768">Mixtral 8x7B</option>
            </optgroup>
            <optgroup label="Cohere">
              <option value="command-r-plus">Command R+</option>
              <option value="command-r">Command R</option>
            </optgroup>
          </select>
        </div>
        <div class="form-group">
          <label for="aiTemperature">Temperature: <span id="tempValue">0.7</span></label>
          <input type="range" id="aiTemperature" min="0" max="2" step="0.1" value="0.7" />
          <p class="form-hint">Baixo = mais preciso, Alto = mais criativo</p>
        </div>
        <div class="form-group">
          <label for="aiTopP">Top P: <span id="topPValue">1.0</span></label>
          <input type="range" id="aiTopP" min="0" max="1" step="0.05" value="1.0" />
          <p class="form-hint">Nucleus sampling (0.8-1.0 recomendado)</p>
        </div>
        <div class="form-group">
          <label for="aiPresencePenalty">Presence Penalty: <span id="presencePenaltyValue">0.0</span></label>
          <input type="range" id="aiPresencePenalty" min="-2" max="2" step="0.1" value="0.0" />
          <p class="form-hint">Incentiva novos tópicos (-2 a 2)</p>
        </div>
        <div class="form-group">
          <label for="aiFrequencyPenalty">Frequency Penalty: <span id="frequencyPenaltyValue">0.0</span></label>
          <input type="range" id="aiFrequencyPenalty" min="-2" max="2" step="0.1" value="0.0" />
          <p class="form-hint">Reduz repetições (-2 a 2)</p>
        </div>
        <div class="form-group">
          <label for="maxTokens">Máximo de Tokens</label>
          <select id="maxTokens">
            <option value="1024">1,024</option>
            <option value="2048">2,048</option>
            <option value="4096" selected>4,096</option>
            <option value="8192">8,192</option>
            <option value="16384">16,384</option>
          </select>
        </div>
        <div class="form-group">
          <label for="systemPrompt">Prompt do Sistema</label>
          <textarea id="systemPrompt" rows="4" placeholder="Instruções para o assistente...">Você é um assistente de IA prestativo. Responda em Português (Brasil), a menos que seja explicitamente solicitado de outra forma.</textarea>
        </div>
        <Button variant="primary" id="saveSettingsBtn" class="btn-full">
          <Icon name="lucide:save" size={18} />
          Salvar Configurações
        </Button>
      </div>
    </div>
  </div>

  <!-- Imagine Modal -->
  <div class="modal-overlay ai-imagine-modal" id="imagineModal">
    <div class="modal">
      <div class="modal-header">
        <h2>Criar Imagem</h2>
        <button class="modal-close" id="closeImagineModal" aria-label="Fechar">&times;</button>
      </div>
      <div class="modal-body">
        <div class="form-group">
          <label for="imagePrompt">Descreva a imagem que deseja criar</label>
          <textarea id="imagePrompt" rows="4" placeholder="Ex: Um gato dourado sentado em uma poltrona azul..."></textarea>
        </div>
        <div class="form-group">
          <label for="imageStyle">Estilo</label>
          <select id="imageStyle">
            <option value="natural">Natural</option>
            <option value="vivid">Vibrante</option>
            <option value="artistic">Artístico</option>
          </select>
        </div>
        <Button variant="primary" id="generateImageBtn" class="btn-full">
          <Icon name="lucide:sparkles" size={18} />
          Gerar Imagem
        </Button>
      </div>
    </div>
  </div>

  <!-- ─── HTML Templates (cloned by src/lib/ai/ui.ts) ─── -->

  <!-- User message -->
  <template id="tpl-message-user">
    <div class="ai-message ai-message-user">
      <div class="ai-message-avatar">
        <Icon name="ai-user" width={20} height={20} />
      </div>
      <div class="ai-message-content">
        <div class="ai-message-images" hidden></div>
        <div class="ai-message-text"></div>
      </div>
    </div>
  </template>

  <!-- Assistant message -->
  <template id="tpl-message-assistant">
    <div class="ai-message ai-message-assistant">
      <div class="ai-message-avatar">
        <Icon name="ai-star" width={20} height={20} />
      </div>
      <div class="ai-message-content">
        <div class="ai-message-images" hidden></div>
        <div class="ai-message-text"></div>
      </div>
    </div>
  </template>

  <!-- Typing indicator -->
  <template id="tpl-typing">
    <div class="ai-message ai-message-assistant">
      <div class="ai-message-avatar">
        <Icon name="ai-star" width={16} height={16} />
      </div>
      <div class="ai-message-content">
        <div class="ai-message-text typing">
          <span class="ai-typing-dot"></span>
          <span class="ai-typing-dot"></span>
          <span class="ai-typing-dot"></span>
        </div>
      </div>
    </div>
  </template>

  <!-- Sidebar chat item -->
  <template id="tpl-chat-item">
    <div class="ai-chat-item">
      <span class="chat-title"></span>
      <button class="chat-delete-btn" aria-label="Excluir conversa">
        <Icon name="lucide:x" width={14} height={14} />
      </button>
    </div>
  </template>

  <!-- Connected project item -->
  <template id="tpl-project-connected">
    <div class="ai-project-item">
      <Icon name="ai-folder" width={24} height={24} />
      <div class="ai-project-info">
        <div class="ai-project-name"></div>
        <div class="ai-project-path"></div>
      </div>
    </div>
    <button class="btn btn-danger disconnect-btn" style="width:100%;margin-top:0.5rem;">
      <Icon name="ai-disconnect" width={16} height={16} />
      Desconectar
    </button>
  </template>

  <!-- Project list item -->
  <template id="tpl-project-list-item">
    <div class="ai-project-item">
      <Icon name="ai-folder" width={24} height={24} />
      <div class="ai-project-info">
        <div class="ai-project-name"></div>
        <div class="ai-project-path"></div>
      </div>
    </div>
  </template>

  <!-- Empty state -->
  <template id="tpl-project-empty">
    <div class="ai-project-empty"><p>Nenhum projeto conectado</p></div>
  </template>

  <script>
    import { initAI } from '../lib/ai/index';
    initAI();
  </script>
</Layout>
