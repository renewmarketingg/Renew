---
import Card from "../components/Card.astro";
import Contact from "../components/Contact.astro";
import Hero from "../components/Hero.astro";
import IconWrapper from "../components/IconWrapper.astro";
import List from "../components/List.astro";
import PricingSection from "../components/PricingSection.astro";
import features from "../constants/features";
import infoCards from "../constants/infoCards";
import services from "../constants/services";
import Layout from "../layouts/Layout.astro";
---

<Layout>
  <Hero />

  <section id="servicos" class="section">
    <div class="container">
      <h2 class="section-title">Nossos Serviços</h2>
      <p class="section-subtitle">Soluções digitais completas para seu negócio</p>
      <div class="services-grid">
        {
          services.map((s) => (
            <Card size="md">
              <IconWrapper name={s.icon} variant="gradient" size={32} />
              <h3>{s.title}</h3>
              <p>{s.description}</p>
            </Card>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section about-section" id="sobre">
    <div class="container">
      <div class="about-content">
        <div class="about-text">
          <span class="about-badge">Sobre Nós</span>
          <h2>
            Transformamos ideias em <span class="highlight">resultados digitais</span>
          </h2>
          <p>A Renew Digital é uma agência de serviços digitais especializada.</p>
          <List
            items={features.map((f) => ({
              icon: 'lucide:check-circle',
              label: f,
            }))}
            variant="icon"
          />
        </div>
        <div class="about-cards">
          {
            infoCards.map((c) => (
              <Card size="sm">
                <IconWrapper name={c.icon} variant="default" size={24} />
                <h3>{c.title}</h3>
                <p>{c.description}</p>
              </Card>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <PricingSection />

  <Contact />
</Layout>

<style>
  .services-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
  }

  .about-section {
    background: linear-gradient(180deg, var(--color-white) 0%, rgba(132, 20, 227, 0.03) 100%);
    transition: background var(--transition-normal);
  }

  .about-content {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 6rem;
    align-items: center;
  }

  .about-badge {
    display: inline-block;
    padding: 0.5rem 1rem;
    background: var(--gradient-primary);
    color: white;
    font-size: 0.875rem;
    font-weight: 600;
    border-radius: 50px;
    margin-bottom: 1rem;
  }

  .about-text h2 {
    font-size: 2.5rem;
    font-weight: 800;
    margin-bottom: 1rem;
    color: var(--color-dark);
  }

  .about-text p {
    color: var(--color-gray-400);
    line-height: 1.8;
    margin-bottom: 1rem;
  }

  .about-cards {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }

  @media (max-width: 992px) {
    .services-grid {
      grid-template-columns: repeat(2, 1fr);
    }
    .about-content {
      grid-template-columns: 1fr;
      gap: 3rem;
    }
    .about-cards {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media (max-width: 768px) {
    .services-grid,
    .about-cards {
      grid-template-columns: 1fr;
    }
    .about-text h2 {
      font-size: 2rem;
    }
  }
</style>
