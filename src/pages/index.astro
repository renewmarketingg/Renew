---
import Button from '../components/button/button.astro';
import Card from '../components/card/card.astro';
import Contact from '../components/contact/contact.astro';
import Hero from '../components/hero/hero.astro';
import IconWrapper from '../components/icon-wrapper/icon-wrapper.astro';
import List from '../components/list/list.astro';
import features from '../constants/features';
import infoCards from '../constants/infoCards';
import services from '../constants/services';
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <Hero />

  <section id="servicos" class="section">
    <div class="container">
      <h2 class="section-title">Nossos Serviços</h2>
      <p class="section-subtitle">Soluções digitais completas para seu negócio</p>
      <div class="services-grid">
        {
          services.map((s) => (
            <Card size="md">
              <IconWrapper name={s.icon} variant="gradient" size={32} />
              <h3>{s.title}</h3>
              <p>{s.description}</p>
            </Card>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section about-section" id="sobre">
    <div class="container">
      <div class="about-content">
        <div class="about-text">
          <span class="about-badge">Sobre Nós</span>
          <h2>
            Transformamos ideias em <span class="highlight">resultados digitais</span>
          </h2>
          <p>A Renew Digital é uma agência de serviços digitais especializada.</p>
          <List
            items={features.map((f) => ({
              icon: 'lucide:check-circle',
              label: f,
            }))}
            variant="icon"
          />
        </div>
        <div class="about-cards">
          {
            infoCards.map((c) => (
              <Card size="sm">
                <IconWrapper name={c.icon} variant="default" size={24} />
                <h3>{c.title}</h3>
                <p>{c.description}</p>
              </Card>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <section class="section cta-section">
    <div class="container">
      <div class="cta-content">
        <h2>Pronto para transformar sua presença digital?</h2>
        <p>Entre em contato e vamos discutir como ajudar seu negócio a crescer</p>
        <Button href="#contato" variant="secondary" class="cta-button" icon="lucide:message-circle">
          Falar com Especialista
        </Button>
      </div>
    </div>
  </section>

  <Contact />
</Layout>

<style>
  .services-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
  }

  .about-section {
    background: linear-gradient(180deg, var(--color-white) 0%, rgba(132, 20, 227, 0.03) 100%);
    transition: background var(--transition-normal);
  }

  .about-content {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 6rem;
    align-items: center;
  }

  .about-badge {
    display: inline-block;
    padding: 0.5rem 1rem;
    background: var(--gradient-primary);
    color: white;
    font-size: 0.875rem;
    font-weight: 600;
    border-radius: 50px;
    margin-bottom: 1rem;
  }

  .about-text h2 {
    font-size: 2.5rem;
    font-weight: 800;
    margin-bottom: 1rem;
    color: var(--color-dark);
  }

  .about-text p {
    color: var(--color-gray-400);
    line-height: 1.8;
    margin-bottom: 1rem;
  }

  .about-cards {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }

  .cta-section {
    background: var(--gradient-primary);
    padding: 6rem 0;
  }

  .cta-content {
    text-align: center;
    color: white;
  }

  .cta-content h2 {
    font-size: 2.5rem;
    font-weight: 800;
    margin-bottom: 1rem;
  }

  .cta-content p {
    font-size: 1.125rem;
    opacity: 0.9;
    margin-bottom: 2rem;
  }

  .cta-content .cta-button {
    background: transparent;
    border: 2px solid rgba(255, 255, 255, 0.3);
    color: white;
  }

  .cta-content .cta-button:hover {
    background: white;
    border-color: white;
    color: var(--color-primary);
  }

  @media (max-width: 992px) {
    .services-grid {
      grid-template-columns: repeat(2, 1fr);
    }
    .about-content {
      grid-template-columns: 1fr;
      gap: 3rem;
    }
    .about-cards {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media (max-width: 768px) {
    .services-grid,
    .about-cards {
      grid-template-columns: 1fr;
    }
    .about-text h2,
    .cta-content h2 {
      font-size: 2rem;
    }
    .cta-content h2 {
      font-size: 1.75rem;
    }
  }
</style>
