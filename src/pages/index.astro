---
import features from '@/constants/features';
import infoCards from '@/constants/infoCards';
import services from '@/constants/services';
import Layout from '@/layouts/Layout.astro';
import S from '@/styles/pages/index.module.css';
import Contact from '@components/Contact/Contact.astro';
import Hero from '@components/Hero/Hero.astro';
import List from '@components/List/List.astro';
import PricingSection from '@components/PricingSection/PricingSection.astro';
import Card from '@components/ui/Card/Card.astro';
import IconWrapper from '@components/ui/IconWrapper/IconWrapper.astro';
---

<Layout>
  <Hero />

  <section id="servicos" class="section">
    <div class="container">
      <h2 class="section-title">Nossos Serviços</h2>
      <p class="section-subtitle">Soluções digitais completas para seu negócio</p>
      <div class={S.servicesGrid}>
        {
          services.map((s) => (
            <Card size="md">
              <IconWrapper name={s.icon} variant="gradient" size={32} />
              <h3>{s.title}</h3>
              <p>{s.description}</p>
            </Card>
          ))
        }
      </div>
    </div>
  </section>

  <section id="sobre" class={`section ${S.aboutSection}`}>
    <div class="container">
      <div class={S.aboutContent}>
        <div class={S.aboutText}>
          <span class={S.aboutBadge}>Sobre Nós</span>
          <h2>
            Transformamos ideias em <span class="highlight">resultados digitais</span>
          </h2>
          <p>A Renew Digital é uma agência de serviços digitais especializada.</p>
          <List
            items={features.map((f) => ({
              icon: 'lucide:check-circle',
              label: f,
            }))}
            variant="icon"
          />
        </div>
        <div class={S.aboutCards}>
          {
            infoCards.map((c) => (
              <Card size="sm">
                <IconWrapper name={c.icon} variant="default" size={24} />
                <h3>{c.title}</h3>
                <p>{c.description}</p>
              </Card>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <PricingSection />

  <Contact />
</Layout>
