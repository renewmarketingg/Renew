---
import Layout from '@/layouts/Layout.astro';
import { Icon } from 'astro-icon/components';
import { getProducts } from '@/services/productService';
import affiliateProducts from '@/constants/affiliateProducts';
import styles from '@/styles/store.module.css';
import Button from '@components/ui/Button/Button.astro';

const dbProducts = await getProducts();
const isDemoMode = dbProducts.length === 0;
const products = isDemoMode ? affiliateProducts : dbProducts;

const uniqueCategories = Array.from(new Set(products.map((p) => p.category)));
const categories = ['Todos', ...uniqueCategories];

const formatPrice = (price: number): string => {
  return new Intl.NumberFormat('pt-BR', { style: 'currency', currency: 'BRL' }).format(price);
};

const calculateDiscount = (originalPrice: number, currentPrice: number): number => {
  return Math.round(((originalPrice - currentPrice) / originalPrice) * 100);
};
---

<Layout
  title="Loja - Produtos Afiliados | Renew Digital"
  description="Encontre os melhores produtos em nossa loja de afiliados. Eletrônicos, gadgets e muito mais com ótimas ofertas."
>
  <div class={styles.cartFloat} id="cartFloat">
    <button class={styles.cartBtn} id="cartBtn" aria-label="Carrinho">
      <Icon name="lucide:shopping-cart" size={24} />
      <span class={styles.cartCount} id="cartCount">0</span>
    </button>
  </div>

  <div class={styles.cartSidebar} id="cartSidebar">
    <div class={styles.cartHeader}>
      <h2><Icon name="lucide:shopping-cart" size={20} /> Carrinho</h2>
      <button class={styles.cartClose} id="cartClose" aria-label="Fechar carrinho">
        <Icon name="lucide:x" size={20} />
      </button>
    </div>
    <div class={styles.cartItems} id="cartItems">
      <p class={styles.cartEmpty} id="cartEmpty">Seu carrinho está vazio</p>
    </div>
    <div class={styles.cartFooter}>
      <div class={styles.cartTotal}>
        <span>Total:</span>
        <span id="cartTotal">R$ 0</span>
      </div>
      <Button fullWidth id="checkoutBtn">
        <Icon name="lucide:credit-card" size={18} />
        Finalizar Compra
      </Button>
      <Button fullWidth id="clearCartBtn" variant="danger">
        <Icon name="lucide:trash-2" size={16} />
        Limpar Carrinho
      </Button>
    </div>
  </div>

  <div class={styles.cartOverlay} id="cartOverlay"></div>

  <section class={styles.storeFilters}>
    <div class="container">
      <div class={styles.filtersContainer}>
        <div class={styles.searchBox}>
          <input type="text" id="searchInput" placeholder="Buscar produtos..." />
          <Icon size="20" class={styles.searchIcon} name="lucide:search" />
        </div>
        <div class="category-filters" id="categoryFilters">
          <button class="btn btn-secondary category-btn active" data-category="Todos">Todos</button>
          {categories.filter((c) => c !== 'Todos').map((cat) => (
            <button class="btn btn-secondary category-btn" data-category={cat}>{cat}</button>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class={styles.productsSection}>
    <div class="container">
      <div id="urlParamsInfo" class={styles.urlParamsInfo}></div>

      {isDemoMode && (
        <div class={styles.demoBanner}>
          <Icon name="lucide:test-tube" size={20} />
          <span>
            <strong>Modo de Demonstração:</strong> Exibindo produtos de teste pois não há produtos reais.
          </span>
        </div>
      )}

      <div class="results-info" style="margin-bottom:1rem">
        <span id="resultsInfo" style="color:var(--color-gray-400)">{products.length} produto{products.length !== 1 ? 's' : ''} encontrado{products.length !== 1 ? 's' : ''}</span>
      </div>

      <div id="productsContainer" class={styles.productsGrid}>
        {products.filter((p) => p.featured).length > 0 && (
          <h2 style="font-size:1.5rem;margin-bottom:1.5rem;grid-column:1/-1">Produtos em Destaque</h2>
        )}
        {products.filter((p) => p.featured).map((product) => (
          <article class={styles.productCard} data-id={product.id} data-name={product.name.toLowerCase()} data-description={product.description.toLowerCase()} data-category={product.category}>
            <div class={styles.productImage}>
              <img src={product.image} alt={product.name} loading="lazy" />
              {product.originalPrice && <span class={styles.productBadge}>Destaque</span>}
            </div>
            <div class={styles.productContent}>
              <span class={styles.productCategory}>{product.category}</span>
              <h3 class={styles.productTitle}>{product.name}</h3>
              <p class={styles.productDescription}>{product.description}</p>
              <div class={styles.productRating}>
                <div class={styles.ratingStars}>
                  {[1,2,3,4,5].map((i) => (
                    <svg width="16" height="16" viewBox="0 0 24 24" fill={i <= Math.round(product.rating) ? 'currentColor' : 'none'} stroke="currentColor" stroke-width="2">
                      <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2" />
                    </svg>
                  ))}
                </div>
                <span class={styles.ratingText}>{product.rating} ({product.reviews.toLocaleString('pt-BR')} avaliações)</span>
              </div>
              <div class={styles.productPrice}>
                <span class={styles.currentPrice}>{formatPrice(product.price)}</span>
                {product.originalPrice && (
                  <>
                    <span class={styles.originalPrice}>{formatPrice(product.originalPrice)}</span>
                    <span class={styles.discount}>-{calculateDiscount(product.originalPrice, product.price)}%</span>
                  </>
                )}
              </div>
              <div class={styles.productActions}>
                <button class="btn btn-secondary add-to-cart-btn" data-id={product.id} data-name={product.name}>
                  <Icon name="lucide:shopping-cart" size={18} /> Adicionar
                </button>
                <a href={product.affiliateLink} target="_blank" rel="noopener noreferrer" class={`btn btn-primary ${styles.productLink}`}>
                  <Icon name="lucide:shopping-bag" size={18} /> Comprar
                </a>
              </div>
            </div>
          </article>
        ))}

        {products.filter((p) => !p.featured).length > 0 && (
          <h2 style="font-size:1.5rem;margin:2rem 0 1.5rem;grid-column:1/-1">{products.filter((p) => p.featured).length > 0 ? 'Outros Produtos' : 'Todos os Produtos'}</h2>
        )}
        {products.filter((p) => !p.featured).map((product) => (
          <article class={styles.productCard} data-id={product.id} data-name={product.name.toLowerCase()} data-description={product.description.toLowerCase()} data-category={product.category}>
            <div class={styles.productImage}>
              <img src={product.image} alt={product.name} loading="lazy" />
              {product.originalPrice && <span class={styles.productBadge}>Oferta</span>}
            </div>
            <div class={styles.productContent}>
              <span class={styles.productCategory}>{product.category}</span>
              <h3 class={styles.productTitle}>{product.name}</h3>
              <p class={styles.productDescription}>{product.description}</p>
              <div class={styles.productRating}>
                <div class={styles.ratingStars}>
                  {[1,2,3,4,5].map((i) => (
                    <svg width="16" height="16" viewBox="0 0 24 24" fill={i <= Math.round(product.rating) ? 'currentColor' : 'none'} stroke="currentColor" stroke-width="2">
                      <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2" />
                    </svg>
                  ))}
                </div>
                <span class={styles.ratingText}>{product.rating} ({product.reviews.toLocaleString('pt-BR')} avaliações)</span>
              </div>
              <div class={styles.productPrice}>
                <span class={styles.currentPrice}>{formatPrice(product.price)}</span>
                {product.originalPrice && (
                  <>
                    <span class={styles.originalPrice}>{formatPrice(product.originalPrice)}</span>
                    <span class={styles.discount}>-{calculateDiscount(product.originalPrice, product.price)}%</span>
                  </>
                )}
              </div>
              <div class={styles.productActions}>
                <button class="btn btn-secondary add-to-cart-btn" data-id={product.id} data-name={product.name}>
                  <Icon name="lucide:shopping-cart" size={18} /> Adicionar
                </button>
                <a href={product.affiliateLink} target="_blank" rel="noopener noreferrer" class={`btn btn-primary ${styles.productLink}`}>
                  <Icon name="lucide:shopping-bag" size={18} /> Comprar
                </a>
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <template id="tpl-cart-item">
    <div class={styles.cartItem}>
      <img src="" alt="" class={styles.cartItemImg} />
      <div class={styles.cartItemInfo}>
        <h4 class="cart-item-name"></h4>
        <span class={styles.cartItemPrice}></span>
        <div class={styles.cartItemQty}>
          <button class={styles.qtyBtn} data-delta="-1">-</button>
          <span class="cart-item-qty-val"></span>
          <button class={styles.qtyBtn} data-delta="1">+</button>
        </div>
      </div>
      <button class={styles.cartItemRemove} aria-label="Remover">
        <Icon name="lucide:x" size={16} />
      </button>
    </div>
  </template>
</Layout>

<script>
  import { initCart } from '@/lib/cart';

  const init = async () => {
    try {
      await initCart();
    } catch (e) {
      console.error('initCart failed:', e);
    }
  };

  const searchInput = document.getElementById('searchInput') as HTMLInputElement | null;
  const categoryButtons = document.querySelectorAll('.category-btn');
  const productsContainer = document.getElementById('productsContainer');

  if (searchInput) {
    let timeout: ReturnType<typeof setTimeout>;
    searchInput.addEventListener('input', (e) => {
      const value = (e.target as HTMLInputElement).value.toLowerCase();
      clearTimeout(timeout);
      timeout = setTimeout(() => {
        filterProducts(value);
      }, 300);
    });
  }

  categoryButtons.forEach((btn) => {
    btn.addEventListener('click', () => {
      const category = btn.getAttribute('data-category') || 'Todos';
      categoryButtons.forEach((b) => b.classList.remove('active'));
      btn.classList.add('active');
      filterProducts(searchInput?.value.toLowerCase() || '', category);
    });
  });

  const filterProducts = (search: string, category = 'Todos') => {
    if (!productsContainer) return;
    const articles = productsContainer.querySelectorAll('article');
    let count = 0;

    articles.forEach((article) => {
      const el = article as HTMLElement;
      const name = el.dataset.name || '';
      const desc = el.dataset.description || '';
      const cat = el.dataset.category || '';

      const matchesSearch = !search || name.includes(search) || desc.includes(search);
      const matchesCategory = category === 'Todos' || cat === category;

      if (matchesSearch && matchesCategory) {
        el.style.display = '';
        count++;
      } else {
        el.style.display = 'none';
      }
    });

    const resultsInfo = document.getElementById('resultsInfo');
    if (resultsInfo) {
      const filters: string[] = [];
      if (search) filters.push(`"${search}"`);
      if (category && category !== 'Todos') filters.push(category);
      const filterText = filters.length > 0 ? ` para ${filters.join(' em ')}` : '';
      resultsInfo.textContent = `${count} produto${count !== 1 ? 's' : ''} encontrado${count !== 1 ? 's' : ''}${filterText}`;
    }
  };

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
</script>
