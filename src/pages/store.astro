---
import Layout from '@/layouts/Layout.astro';
import { Icon } from 'astro-icon/components';
import { getProducts } from '@/services/productService';
import affiliateProducts from '@/constants/affiliateProducts';
import ProductCard from '@components/ProductCard/ProductCard.astro';
import styles from '@/styles/store.module.css';
import Button from '@components/ui/Button/Button.astro';

const dbProducts = await getProducts();
const isDemoMode = dbProducts.length === 0;
const products = isDemoMode ? affiliateProducts : dbProducts;

const featuredProducts = products.filter((p) => p.featured);
const otherProducts = products.filter((p) => !p.featured);
---

<Layout
  title="Loja - Produtos Afiliados | Renew Digital"
  description="Encontre os melhores produtos em nossa loja de afiliados. Eletrônicos, acessórios e muito mais com ótimas ofertas."
>
  <div class={styles.cartFloat} id="cartFloat">
    <button class={styles.cartBtn} id="cartBtn" aria-label="Carrinho">
      <Icon name="lucide:shopping-cart" size={24} />
      <span class={styles.cartCount} id="cartCount">0</span>
    </button>
  </div>

  <div class={styles.cartSidebar} id="cartSidebar">
    <div class={styles.cartHeader}>
      <h2><Icon name="lucide:shopping-cart" size={20} /> Carrinho</h2>
      <button class={styles.cartClose} id="cartClose" aria-label="Fechar carrinho">
        <Icon name="lucide:x" size={20} />
      </button>
    </div>
    <div class={styles.cartItems} id="cartItems">
      <p class={styles.cartEmpty} id="cartEmpty">Seu carrinho está vazio</p>
    </div>
    <div class={styles.cartFooter}>
      <div class={styles.cartTotal}>
        <span>Total:</span>
        <span id="cartTotal">{'R$ 0'}</span>
      </div>
      <Button fullWidth id="checkoutBtn">
        <Icon name="lucide:credit-card" size={18} />
        Finalizar Compra
      </Button>
      <Button fullWidth id="clearCartBtn" variant="danger">
        <Icon name="lucide:trash-2" size={16} />
        Limpar Carrinho
      </Button>
    </div>
  </div>

  <div class={styles.cartOverlay} id="cartOverlay"></div>

  <section class={styles.storeFilters}>
    <div class="container">
      <div class={styles.filtersContainer}>
        <div class={styles.searchBox}>
          <input type="text" id="searchInput" placeholder="Buscar produtos..." />
          <Icon size="20" class={styles.searchIcon} name="lucide:search" />
        </div>
        <div class="category-filters" id="categoryFilters">
          <button class="btn btn-secondary category-btn active" data-category="Todos">Todos</button>
          {
            ['Eletrônicos', 'Áudio', 'Games', 'Livros', 'Acessórios'].map((cat) => (
              <button class="btn btn-secondary category-btn" data-category={cat}>
                {cat}
              </button>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <section class={styles.productsSection}>
    <div class="container">
      {
        isDemoMode && (
          <div class={styles.demoBanner}>
            <Icon name="lucide:test-tube" size={20} />
            <span>
              <strong>Modo de Demonstração:</strong> Exibindo produtos de teste pois não há produtos
              reais.
            </span>
          </div>
        )
      }

      <div class={styles.resultsInfo} id="resultsInfo">
        {products.length} produto{products.length !== 1 ? 's' : ''} encontrado{products.length !== 1 ? 's' : ''}
      </div>

      <div id="productsContainer">
        {featuredProducts.length > 0 && (
          <section class={styles.productsSection}>
            <h2 class={styles.sectionTitle}>Produtos em Destaque</h2>
            <div class={styles.productsGrid}>
              {featuredProducts.map((product) => <ProductCard product={product as any} />)}
            </div>
          </section>
        )}

        {otherProducts.length > 0 && (
          <section class={styles.productsSection}>
            <h2 class={styles.sectionTitle}>
              {featuredProducts.length > 0 ? 'Outros Produtos' : 'Todos os Produtos'}
            </h2>
            <div class={styles.productsGrid}>
              {otherProducts.map((product) => <ProductCard product={product as any} />)}
            </div>
          </section>
        )}
      </div>
    </div>
  </section>

  <template id="tpl-cart-item">
    <div class={styles.cartItem}>
      <div class={styles.cartItemImg}></div>
      <div class={styles.cartItemInfo}>
        <h4 class="cart-item-name"></h4>
        <span class={styles.cartItemPrice}></span>
        <div class={styles.cartItemQty}>
          <button class={styles.qtyBtn} data-action="decrease">−</button>
          <span class="cart-item-qty-val">1</span>
          <button class={styles.qtyBtn} data-action="increase">+</button>
        </div>
      </div>
      <button class={styles.cartItemRemove} aria-label="Remover">
        <Icon name="lucide:x" size={16} />
      </button>
    </div>
  </template>
</Layout>

<script>
  import { initCart } from '@/lib/cart';

  const init = () => {
    try {
      initCart();
    } catch (e) {
      console.error('initCart failed:', e);
    }
  };

  const searchInput = document.getElementById('searchInput') as HTMLInputElement | null;
  const categoryButtons = document.querySelectorAll('.category-btn');
  const productsContainer = document.getElementById('productsContainer');

  if (searchInput) {
    let timeout: ReturnType<typeof setTimeout>;
    searchInput.addEventListener('input', (e) => {
      const value = (e.target as HTMLInputElement).value.toLowerCase();
      clearTimeout(timeout);
      timeout = setTimeout(() => {
        filterProducts(value);
      }, 300);
    });
  }

  categoryButtons.forEach((btn) => {
    btn.addEventListener('click', () => {
      const category = btn.getAttribute('data-category') || 'Todos';
      categoryButtons.forEach((b) => b.classList.remove('active'));
      btn.classList.add('active');
      filterProducts(searchInput?.value.toLowerCase() || '', category);
    });
  });

  const filterProducts = (search: string, category = 'Todos') => {
    if (!productsContainer) return;
    const articles = productsContainer.querySelectorAll('article');
    let count = 0;

    articles.forEach((article) => {
      const el = article as HTMLElement;
      const name = el.dataset.name || '';
      const desc = el.dataset.description || '';
      const cat = el.dataset.category || '';

      const matchesSearch = !search || name.includes(search) || desc.includes(search);
      const matchesCategory = category === 'Todos' || cat === category;

      if (matchesSearch && matchesCategory) {
        el.style.display = '';
        count++;
      } else {
        el.style.display = 'none';
      }
    });

    const resultsInfo = document.getElementById('resultsInfo');
    if (resultsInfo) {
      const filters: string[] = [];
      if (search) filters.push(`"${search}"`);
      if (category && category !== 'Todos') filters.push(category);
      const filterText = filters.length > 0 ? ` para ${filters.join(' em ')}` : '';
      const word = count === 1 ? 'produto' : 'produtos';
      const found = count === 1 ? 'encontrado' : 'encontrados';
      resultsInfo.textContent = `${count} ${word} ${found}${filterText}`;
    }
  };

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
</script>
