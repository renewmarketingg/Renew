---
import Layout from '../../layouts/Layout.astro';
import { Icon } from 'astro-icon/components';
import PageHeader from '@components/PageHeader/PageHeader.astro';
import Button from '@components/ui/Button/Button.astro';
import StatsGrid from '@components/ui/AdminStatsGrid/AdminStatsGrid.astro';
import Filters from '@components/ui/AdminFilters/AdminFilters.astro';
import Modal from '@components/ui/AdminModal/AdminModal.astro';

const categories = ['auth', 'api', 'system'];
const levels = ['info', 'warning', 'error', 'success'];

const stats = [
  { label: 'Total', value: '0', statKey: 'total', icon: 'lucide:file-text' },
  {
    label: 'Erros',
    value: '0',
    statKey: 'errors',
    icon: 'lucide:alert-circle',
    iconBg: 'rgba(239,68,68,0.1)',
    iconColor: '#ef4444',
  },
  {
    label: 'Alertas',
    value: '0',
    statKey: 'warnings',
    icon: 'lucide:alert-triangle',
    iconBg: 'rgba(251,191,36,0.1)',
    iconColor: '#fbbf24',
  },
  {
    label: 'Última att',
    value: '--',
    statKey: 'lastUpdate',
    icon: 'lucide:check-circle',
    iconBg: 'rgba(34,197,94,0.1)',
    iconColor: '#22c55e',
  },
];

const filters = [
  {
    id: 'isTest',
    label: 'Logs de teste',
    type: 'checkbox' as const,
  },
  {
    id: 'level',
    label: 'Nível',
    type: 'select' as const,
    options: levels.map((l) => ({ value: l, label: l.charAt(0).toUpperCase() + l.slice(1) })),
  },
  {
    id: 'category',
    label: 'Categoria',
    type: 'select' as const,
    options: categories.map((c) => ({ value: c, label: c })),
  },
];
---

<Layout title="Logs do Sistema" adm={true} activePage="/admin/logs">
  <div class="admin-content">
    <PageHeader title="Logs do Sistema">
      <div class="flex gap-2">
        <Button id="exportBtn" variant="secondary">
          <Icon name="lucide:download" size={18} />Exportar
        </Button>
        <Button id="clearBtn" variant="danger">
          <Icon name="lucide:trash-2" size={18} />Limpar
        </Button>
      </div>
    </PageHeader>

    <StatsGrid {stats} />

    <Filters searchPlaceholder="Buscar logs..." {filters} />

    <div class="table-wrapper">
      <table class="table">
        <thead>
          <tr>
            <th>Timestamp</th>
            <th>Nível</th>
            <th>Categoria</th>
            <th>Mensagem</th>
            <th></th>
          </tr>
        </thead>
        <tbody id="logsTableBody"></tbody>
      </table>
    </div>
  </div>

  <Modal id="detailModal" title="Detalhes do Log" size="lg">
    <div id="detailContent"></div>
  </Modal>

  <Modal id="clearModal" title="Limpar Logs?" size="sm">
    <p>Todos os logs serão excluídos.</p>
    <div slot="footer">
      <Button id="cancelClearBtn" variant="secondary">Cancelar</Button>
      <Button id="confirmClearBtn" variant="danger">Limpar</Button>
    </div>
  </Modal>
</Layout>

<script>
  import { initLogsAdmin } from '../../lib/logs-admin';
  initLogsAdmin();
</script>
