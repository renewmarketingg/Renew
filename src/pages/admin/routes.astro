---
import Layout from '@/layouts/Layout.astro';
import { Icon } from 'astro-icon/components';
import PageHeader from '@components/PageHeader/PageHeader.astro';
import Button from '@components/ui/Button/Button.astro';
import AdminStatsGrid from '@components/ui/AdminStatsGrid/AdminStatsGrid.astro';
import AdminFilters from '@components/ui/AdminFilters/AdminFilters.astro';
import AdminModal from '@components/ui/AdminModal/AdminModal.astro';

const categories = ['Público', 'Documentação', 'Admin', 'Sistema', 'Blog', 'API', 'Custom'];

const stats = [
  { label: 'Total', value: '0', statKey: 'total', icon: 'lucide:route' },
  { label: 'Dinâmicas', value: '0', statKey: 'dynamic', icon: 'lucide:git-branch' },
  { label: 'Categorias', value: '0', statKey: 'categories', icon: 'lucide:folder' },
  { label: 'Ativas', value: '0', statKey: 'active', icon: 'lucide:toggle-left' },
];

const filters = [
  {
    id: 'category',
    label: 'Categoria',
    type: 'select' as const,
    options: categories.map((c) => ({ value: c, label: c })),
  },
  {
    id: 'dynamic',
    label: 'Tipo',
    type: 'select' as const,
    options: [
      { value: 'true', label: 'Dinâmica' },
      { value: 'false', label: 'Estática' },
    ],
  },
  {
    id: 'status',
    label: 'Status',
    type: 'select' as const,
    options: [
      { value: 'active', label: 'Ativa' },
      { value: 'inactive', label: 'Inativa' },
    ],
  },
];
---

<Layout title="Gerenciar Rotas" adm={true} activePage="/admin/routes">
  <div class="admin-content">
    <PageHeader title="Gerenciar Rotas">
      <Button id="addBtn" variant="primary"><Icon name="lucide:plus" size={18} />Nova rota</Button>
    </PageHeader>

    <AdminStatsGrid {stats} />
    <AdminFilters searchPlaceholder="Buscar rotas..." {filters} />

    <div class="card-grid" id="grid"></div>
  </div>

  <AdminModal id="itemModal" title="Nova Rota">
    <form id="itemForm">
      <input type="hidden" id="itemId" />
      <div class="form-group">
        <label for="label">Label</label><input type="text" id="label" required />
      </div>
      <div class="form-group">
        <label for="path">Path</label><input type="text" id="path" required />
      </div>
      <div class="form-group">
        <label for="description">Descrição</label><input type="text" id="description" />
      </div>
      <div class="form-row">
        <div class="form-group">
          <label for="category">Categoria</label>
          <select id="category" required>{categories.map((c) => <option value={c}>{c}</option>)}</select>
        </div>
        <div class="form-group">
          <div class="checkbox-group mt-4">
            <input type="checkbox" id="dynamic" /><label for="dynamic">Dinâmica</label>
          </div>
        </div>
      </div>
      <div class="form-group" id="paramsGroup" style="display:none">
        <label for="dynamicParams">Parâmetros</label><input type="text" id="dynamicParams" />
      </div>
    </form>
    <div slot="footer">
      <Button id="cancelBtn" variant="secondary">Cancelar</Button>
      <Button id="saveBtn" variant="primary">Salvar</Button>
    </div>
  </AdminModal>

  <AdminModal id="deleteModal" title="Excluir?" size="sm">
    <p>Excluir <strong id="deleteName"></strong>?</p>
    <div slot="footer">
      <Button id="cancelDeleteBtn" variant="secondary">Cancelar</Button>
      <Button id="confirmDeleteBtn" variant="danger">Excluir</Button>
    </div>
  </AdminModal>
</Layout>

<script>
  import { initRoutesAdmin } from '@/lib/routes-admin';
  initRoutesAdmin();
</script>
