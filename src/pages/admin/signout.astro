---
export const prerender = false;
import { SignOutButton } from "@clerk/astro/components";
import Layout from "../../layouts/Layout.astro";
---

<Layout title="Sair - Admin Renew Digital" adm={true} hideHeaderFooter={true}>
  <div class="login-page">
    <div class="login-container">
      <div class="login-brand">
        <img
          src="/renew.png"
          alt="Renew Digital"
          class="login-logo-img"
          loading="eager"
          decoding="async"
        />
        <h1>Sair</h1>
        <p>Painel Administrativo</p>
      </div>

      <div class="logout-card">
        <p>Tem certeza que deseja sair?</p>
        <SignOutButton redirectUrl="/">
          <button class="logout-button">Sair</button>
        </SignOutButton>
      </div>

      <a href="/admin" class="back-link">← Voltar para o admin</a>
    </div>
  </div>
</Layout>

<style>
  .login-page {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem;
    background: linear-gradient(135deg, #8414e3 0%, #c51be4 100%);
  }

  .login-container {
    width: 100%;
    max-width: 400px;
  }

  .login-brand {
    text-align: center;
    margin-bottom: 2rem;
  }

  .login-logo-img {
    width: 80px;
    height: 80px;
    object-fit: contain;
    margin-bottom: 1rem;
    background: white;
    border-radius: 16px;
    padding: 0.5rem;
  }

  .login-brand h1 {
    font-size: 1.75rem;
    font-weight: 800;
    color: white;
    margin-bottom: 0.25rem;
  }

  .login-brand p {
    font-size: 0.875rem;
    color: rgba(255, 255, 255, 0.8);
  }

  .logout-card {
    background: white;
    border-radius: 16px;
    padding: 2rem;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.2);
    text-align: center;
  }

  .logout-card p {
    color: #666;
    margin-bottom: 1.5rem;
  }

  .logout-button {
    display: inline-block;
    width: 100%;
    padding: 0.875rem 1.5rem;
    background: #ef4444;
    color: white;
    text-decoration: none;
    border: none;
    border-radius: 8px;
    font-weight: 600;
    font-size: 1rem;
    cursor: pointer;
    transition: background 0.2s;
  }

  .logout-button:hover {
    background: #dc2626;
  }

  .back-link {
    display: block;
    text-align: center;
    margin-top: 1.5rem;
    color: white;
    text-decoration: none;
    font-size: 0.875rem;
    opacity: 0.9;
  }

  .back-link:hover {
    opacity: 1;
  }

  @media (max-width: 480px) {
    .login-page {
      padding: 1rem;
    }
    .logout-card {
      padding: 1.5rem;
    }
    .login-logo-img {
      width: 60px;
      height: 60px;
    }
  }
</style>
