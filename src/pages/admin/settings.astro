---
import Layout from '@/layouts/Layout.astro';
import { Icon } from 'astro-icon/components';
import PageHeader from '@components/PageHeader/PageHeader.astro';
import Button from '@components/ui/Button/Button.astro';
import styles from '@/styles/admin/settings.module.css';
---

<Layout title="Configurações" adm={true} activePage="/admin/settings">
  <div class="admin-content">
    <PageHeader title="Configurações">
      <Button id="saveSettingsBtn" variant="primary">
        <Icon name="lucide:save" size={18} />
        Salvar Configurações
      </Button>
    </PageHeader>

    <div class={styles.settingsGrid} id="settingsForm">
      <div class={styles.settingsSection}>
        <div class={styles.settingsHeader}>
          <Icon name="lucide:globe" size={24} />
          <h2>Informações do Site</h2>
        </div>
        <div class={styles.settingsBody}>
          <div class="form-group">
            <label for="siteName">Nome do Site</label>
            <input type="text" id="siteName" data-field="siteName" />
          </div>
          <div class="form-group">
            <label for="siteDescription">Descrição</label>
            <textarea id="siteDescription" data-field="siteDescription" rows="3"></textarea>
          </div>
          <div class="form-group">
            <label for="siteUrl">URL do Site</label>
            <input type="url" id="siteUrl" data-field="siteUrl" />
          </div>
          <div class="form-group">
            <label for="contactEmail">Email de Contato</label>
            <input type="email" id="contactEmail" data-field="contactEmail" />
          </div>
          <div class="form-group">
            <label for="contactPhone">Telefone</label>
            <input type="tel" id="contactPhone" data-field="contactPhone" />
          </div>
        </div>
      </div>

      <div class={styles.settingsSection}>
        <div class={styles.settingsHeader}>
          <Icon name="lucide:palette" size={24} />
          <h2>Aparência</h2>
        </div>
        <div class={styles.settingsBody}>
          <div class="form-group">
            <label for="themeSelect">Tema Padrão</label>
            <select id="themeSelect" data-field="theme">
              <option value="dark">Escuro</option>
              <option value="light">Claro</option>
              <option value="system">Sistema</option>
            </select>
          </div>
          <div class="form-group">
            <label for="primaryColor">Cor Primária</label>
            <div class={styles.colorInputWrapper}>
              <input type="color" id="primaryColor" data-field="primaryColor" />
              <input type="text" id="primaryColorText" data-sync="primaryColor" />
            </div>
          </div>
          <div class="form-group">
            <label for="secondaryColor">Cor Secundária</label>
            <div class={styles.colorInputWrapper}>
              <input type="color" id="secondaryColor" data-field="secondaryColor" />
              <input type="text" id="secondaryColorText" data-sync="secondaryColor" />
            </div>
          </div>
          <div class="checkbox-group">
            <input
              type="checkbox"
              id="enableAnimations"
              data-field-bool="enableAnimations"
              checked
            />
            <label for="enableAnimations">Habilitar Animações</label>
          </div>
          <div class="checkbox-group">
            <input
              type="checkbox"
              id="enableTransitions"
              data-field-bool="enableTransitions"
              checked
            />
            <label for="enableTransitions">Habilitar Transições</label>
          </div>
        </div>
      </div>

      <div class={styles.settingsSection}>
        <div class={styles.settingsHeader}>
          <Icon name="lucide:shopping-cart" size={24} />
          <h2>Loja de Produtos</h2>
        </div>
        <div class={styles.settingsBody}>
          <div class="form-group">
            <label for="storeTitle">Título da Página</label>
            <input type="text" id="storeTitle" data-field="storeTitle" />
          </div>
          <div class="form-group">
            <label for="storeSubtitle"> Subtítulo</label>
            <input type="text" id="storeSubtitle" data-field="storeSubtitle" />
          </div>
          <div class="form-group">
            <label for="productsPerPage">Produtos por Página</label>
            <input
              type="number"
              id="productsPerPage"
              data-field-num="productsPerPage"
              min="6"
              max="50"
            />
          </div>
          <div class="checkbox-group">
            <input type="checkbox" id="showPrices" data-field-bool="showPrices" checked />
            <label for="showPrices">Mostrar Preços</label>
          </div>
          <div class="checkbox-group">
            <input type="checkbox" id="showDiscounts" data-field-bool="showDiscounts" checked />
            <label for="showDiscounts">Mostrar Descontos</label>
          </div>
          <div class="checkbox-group">
            <input
              type="checkbox"
              id="enableAffiliateLinks"
              data-field-bool="enableAffiliateLinks"
              checked
            />
            <label for="enableAffiliateLinks">Habilitar Links de Afiliado</label>
          </div>
        </div>
      </div>

      <div class={styles.settingsSection}>
        <div class={styles.settingsHeader}>
          <Icon name="lucide:shield" size={24} />
          <h2>Segurança</h2>
        </div>
        <div class={styles.settingsBody}>
          <div class="form-group">
            <label for="sessionTimeout">Timeout da Sessão (minutos)</label>
            <input
              type="number"
              id="sessionTimeout"
              data-field-num="sessionTimeout"
              min="15"
              max="480"
            />
          </div>
          <div class="checkbox-group">
            <input type="checkbox" id="enable2FA" data-field-bool="enable2FA" />
            <label for="enable2FA">Habilitar Autenticação em Dois Fatores</label>
          </div>
          <div class="checkbox-group">
            <input type="checkbox" id="logAdminActions" data-field-bool="logAdminActions" checked />
            <label for="logAdminActions">Registrar Ações do Admin</label>
          </div>
          <div class="checkbox-group">
            <input
              type="checkbox"
              id="requireEmailVerification"
              data-field-bool="requireEmailVerification"
              checked
            />
            <label for="requireEmailVerification">Exigir Verificação de Email</label>
          </div>
        </div>
      </div>

      <div class={styles.settingsSection}>
        <div class={styles.settingsHeader}>
          <Icon name="lucide:search" size={24} />
          <h2>SEO</h2>
        </div>
        <div class={styles.settingsBody}>
          <div class="form-group">
            <label for="metaTitle">Title Tag Padrão</label>
            <input type="text" id="metaTitle" data-field="metaTitle" />
          </div>
          <div class="form-group">
            <label for="metaDescription">Meta Description Padrão</label>
            <textarea id="metaDescription" data-field="metaDescription" rows="3"></textarea>
          </div>
          <div class="form-group">
            <label for="googleAnalyticsId">Google Analytics ID</label>
            <input
              type="text"
              id="googleAnalyticsId"
              data-field="googleAnalyticsId"
              placeholder="G-XXXXXXXXXX"
            />
          </div>
          <div class="form-group">
            <label for="googleTagManagerId">Google Tag Manager ID</label>
            <input
              type="text"
              id="googleTagManagerId"
              data-field="googleTagManagerId"
              placeholder="GTM-XXXXXXX"
            />
          </div>
          <div class="checkbox-group">
            <input type="checkbox" id="enableSitemap" data-field-bool="enableSitemap" checked />
            <label for="enableSitemap">Habilitar Sitemap Automático</label>
          </div>
        </div>
      </div>

      <div class={styles.settingsSection}>
        <div class={styles.settingsHeader}>
          <Icon name="lucide:mail" size={24} />
          <h2>Email</h2>
        </div>
        <div class={styles.settingsBody}>
          <div class="form-group">
            <label for="smtpHost">Servidor SMTP</label>
            <input type="text" id="smtpHost" data-field="smtpHost" placeholder="smtp.example.com" />
          </div>
          <div class="form-group">
            <label for="smtpPort">Porta SMTP</label>
            <input type="number" id="smtpPort" data-field-num="smtpPort" />
          </div>
          <div class="form-group">
            <label for="smtpUser">Usuário SMTP</label>
            <input type="text" id="smtpUser" data-field="smtpUser" placeholder="user@example.com" />
          </div>
          <div class="form-group">
            <label for="smtpPassword">Senha SMTP</label>
            <input
              type="password"
              id="smtpPassword"
              data-field="smtpPassword"
              placeholder="••••••••"
            />
          </div>
          <div class="checkbox-group">
            <input
              type="checkbox"
              id="enableEmailNotifications"
              data-field-bool="enableEmailNotifications"
              checked
            />
            <label for="enableEmailNotifications">Habilitar Notificações por Email</label>
          </div>
        </div>
      </div>
    </div>
  </div>
</Layout>

<script>
  import { showToast } from '../../lib/admin';

  const STORAGE_KEY = 'site_settings';

  const defaultSettings = {
    siteName: 'Renew Digital',
    siteDescription: 'Serviços digitais especializados para impulsionar seu negócio',
    siteUrl: 'https://renewdigital.com.br',
    contactEmail: 'contato@renewdigital.com.br',
    contactPhone: '+5543998280078',
    theme: 'dark',
    primaryColor: '#8414e3',
    secondaryColor: '#c51be4',
    enableAnimations: true,
    enableTransitions: true,
    storeTitle: 'Nossos Produtos',
    storeSubtitle: 'Produtos selecionados para você',
    productsPerPage: 12,
    showPrices: true,
    showDiscounts: true,
    enableAffiliateLinks: true,
    sessionTimeout: 60,
    enable2FA: false,
    logAdminActions: true,
    requireEmailVerification: true,
    metaTitle: '{title} | Renew Digital',
    metaDescription: 'Serviços digitais especializados para impulsionar seu negócio',
    googleAnalyticsId: '',
    googleTagManagerId: '',
    enableSitemap: true,
    smtpHost: '',
    smtpPort: 587,
    smtpUser: '',
    smtpPassword: '',
    enableEmailNotifications: true,
  };

  function loadSettings() {
    const stored = localStorage.getItem(STORAGE_KEY);
    return stored ? { ...defaultSettings, ...JSON.parse(stored) } : defaultSettings;
  }

  function saveSettings() {
    const settings: Record<string, unknown> = {};

    document.querySelectorAll<HTMLInputElement>('[data-field]').forEach((el) => {
      settings[el.dataset.field!] = el.value;
    });

    document.querySelectorAll<HTMLInputElement>('[data-field-num]').forEach((el) => {
      settings[el.dataset.fieldNum!] = parseInt(el.value) || 0;
    });

    document.querySelectorAll<HTMLInputElement>('[data-field-bool]').forEach((el) => {
      settings[el.dataset.fieldBool!] = el.checked;
    });

    localStorage.setItem(STORAGE_KEY, JSON.stringify(settings));
    showToast('Configurações salvas com sucesso!', 'success');
  }

  function populateForm(settings: Record<string, unknown>) {
    document.querySelectorAll<HTMLInputElement>('[data-field]').forEach((el) => {
      if (settings[el.dataset.field!]) el.value = settings[el.dataset.field!] as string;
    });

    document.querySelectorAll<HTMLInputElement>('[data-field-num]').forEach((el) => {
      const key = el.dataset.fieldNum!;
      if (settings[key]) el.value = String(settings[key]);
    });

    document.querySelectorAll<HTMLInputElement>('[data-field-bool]').forEach((el) => {
      el.checked = Boolean(settings[el.dataset.fieldBool!]);
    });

    const primaryColor = settings.primaryColor as string;
    const secondaryColor = settings.secondaryColor as string;
    if (primaryColor) {
      (document.getElementById('primaryColor') as HTMLInputElement).value = primaryColor;
      (document.getElementById('primaryColorText') as HTMLInputElement).value = primaryColor;
    }
    if (secondaryColor) {
      (document.getElementById('secondaryColor') as HTMLInputElement).value = secondaryColor;
      (document.getElementById('secondaryColorText') as HTMLInputElement).value = secondaryColor;
    }
  }

  function syncColorInputs(colorId: string, textId: string) {
    const colorInput = document.getElementById(colorId) as HTMLInputElement;
    const textInput = document.getElementById(textId) as HTMLInputElement;

    colorInput?.addEventListener('input', () => {
      if (textInput) textInput.value = colorInput.value;
    });

    textInput?.addEventListener('input', () => {
      if (colorInput) colorInput.value = textInput.value;
    });
  }

  document.getElementById('saveSettingsBtn')?.addEventListener('click', saveSettings);

  syncColorInputs('primaryColor', 'primaryColorText');
  syncColorInputs('secondaryColor', 'secondaryColorText');

  populateForm(loadSettings());
</script>
