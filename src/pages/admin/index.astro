---
import Layout from '../../layouts/Layout.astro';
import { Icon } from 'astro-icon/components';
import PageHeader from '@components/PageHeader/PageHeader.astro';
import StatsGrid from '@components/ui/AdminStatsGrid/AdminStatsGrid.astro';
import '../../styles/admin/admin.css';

const stats = [
  { label: 'Visitas Hoje', value: '-', statKey: 'visits', icon: 'lucide:eye' },
  { label: 'Usuários', value: '-', statKey: 'users', icon: 'lucide:users' },
  { label: 'Vendas', value: '-', statKey: 'sales', icon: 'lucide:shopping-cart' },
  { label: 'Faturamento', value: '-', statKey: 'revenue', icon: 'lucide:trending-up' },
];
---

<Layout title="Dashboard" adm={true} activePage="/admin">
  <div class="admin-content">
    <PageHeader title="Dashboard" />

    <StatsGrid {stats} />

    <div class="admin-grid-2">
      <div class="card">
        <div class="card-header">
          <h3><Icon name="lucide:activity" size={20} /> Atividade Recente</h3>
        </div>
        <div class="card-body">
          <p style="color: var(--color-gray-400);">Nenhuma atividade recente.</p>
        </div>
      </div>
      <div class="card">
        <div class="card-header">
          <h3><Icon name="lucide:info" size={20} /> Informações</h3>
        </div>
        <div class="card-body">
          <div class="info-row"><span>Páginas</span><strong>1</strong></div>
          <div class="info-row"><span>Produtos</span><strong data-stat="products">-</strong></div>
          <div class="info-row"><span>Modo</span><strong>Admin</strong></div>
        </div>
      </div>
    </div>
  </div>
</Layout>
