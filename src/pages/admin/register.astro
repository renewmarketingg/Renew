---
export const prerender = false;
import Layout from '../../layouts/Layout.astro';
import { SignUp } from '@clerk/astro/components';

const token = Astro.url.searchParams.get('token') || '';
---

<Layout title="Convite - Admin Renew Digital" adm={true} hideHeaderFooter={true}>
  <div class="login-page">
    <div class="login-container">
      <div class="login-brand">
        <img src="/renew.png" alt="Renew Digital" class="login-logo-img" loading="eager" />
        <h1>Você foi convidado!</h1>
        <p>Crie sua conta para acessar o painel administrativo</p>
      </div>

      <div class="clerk-login">
        <SignUp
          appearance={{
            elements: {
              rootBox: 'clerk-root',
              card: 'clerk-card',
              formButtonPrimary: 'clerk-button-primary',
              formFieldInput: 'clerk-input',
              footerActionLink: 'clerk-link',
            },
          }}
          fallbackRedirectUrl="/admin"
        />
      </div>

      <a href="/" class="back-link">← Voltar para o site</a>
    </div>
  </div>
</Layout>

<script is:inline define:vars={{ token }}>
  const INVITES_KEY = 'admin_invites';

  function validateToken(t) {
    if (!t) return false;
    const invites = JSON.parse(localStorage.getItem(INVITES_KEY) || '[]');
    const invite = invites.find((inv) => inv.token === t && !inv.used);
    return invite || null;
  }

  function markTokenUsed(t, userId) {
    const invites = JSON.parse(localStorage.getItem(INVITES_KEY) || '[]');
    const idx = invites.findIndex((inv) => inv.token === t);
    if (idx !== -1) {
      invites[idx].used = true;
      invites[idx].usedBy = userId;
      invites[idx].usedAt = new Date().toISOString();
      localStorage.setItem(INVITES_KEY, JSON.stringify(invites));
    }
  }

  if (token) {
    const invite = validateToken(token);
    if (!invite) {
      document.body.innerHTML = `
        <div style="min-height:100vh;display:flex;align-items:center;justify-content:center;background:linear-gradient(135deg,#8414e3,#c51be4);">
          <div style="background:white;padding:2rem;border-radius:16px;text-align:center;max-width:400px;">
            <h1 style="color:#ef4444;margin-bottom:1rem;">Link inválido</h1>
            <p style="color:#666;">Este convite já foi usado ou expirou.</p>
            <a href="/" style="display:inline-block;margin-top:1rem;color:#8414e3;">Voltar ao site</a>
          </div>
        </div>
      `;
    }
  }
</script>

<style>
  .login-page {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem;
    background: linear-gradient(135deg, #8414e3 0%, #c51be4 100%);
  }

  .login-container {
    width: 100%;
    max-width: 400px;
  }

  .login-brand {
    text-align: center;
    margin-bottom: 2rem;
  }

  .login-logo-img {
    width: 80px;
    height: 80px;
    object-fit: contain;
    margin-bottom: 1rem;
    background: white;
    border-radius: 16px;
    padding: 0.5rem;
  }

  .login-brand h1 {
    font-size: 1.5rem;
    font-weight: 800;
    color: white;
    margin-bottom: 0.25rem;
  }

  .login-brand p {
    font-size: 0.875rem;
    color: rgba(255, 255, 255, 0.8);
  }

  .clerk-login {
    background: white;
    border-radius: 16px;
    padding: 2rem;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.2);
  }

  .back-link {
    display: block;
    text-align: center;
    margin-top: 1.5rem;
    color: white;
    text-decoration: none;
    font-size: 0.875rem;
    opacity: 0.9;
  }

  @media (max-width: 480px) {
    .login-page {
      padding: 1rem;
    }
    .clerk-login {
      padding: 1.5rem;
    }
    .login-logo-img {
      width: 60px;
      height: 60px;
    }
  }

  :global(.clerk-card) {
    box-shadow: none !important;
    border: none !important;
    width: 100% !important;
  }

  :global(.clerk-root) {
    width: 100%;
  }

  :global(.clerk-button-primary) {
    background: #8414e3 !important;
    width: 100%;
  }

  :global(.clerk-button-primary:hover) {
    background: #7c3aed !important;
  }

  :global(.clerk-input) {
    width: 100%;
    padding: 0.75rem;
    border: 1px solid #e5e7eb;
    border-radius: 8px;
  }

  :global(.clerk-link) {
    color: #8414e3;
  }
</style>
