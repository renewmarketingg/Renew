---
export const prerender = false;
import Layout from "../../layouts/Layout.astro";
import { SignIn } from "@clerk/astro/components";
---

<Layout title="Login - Admin Renew Digital" adm={true} hideHeaderFooter={true}>
  <div class="login-page">
    <div class="login-container">
      <div class="login-brand">
        <img
          src="/renew.png"
          alt="Renew Digital"
          class="login-logo-img"
          loading="eager"
          decoding="async"
        />
        <h1>Renew Digital</h1>
        <p>Painel Administrativo</p>
      </div>

      <div class="clerk-login">
        <SignIn
          appearance={{
            elements: {
              rootBox: "clerk-root",
              card: "clerk-card",
              formButtonPrimary: "clerk-button-primary",
              formFieldInput: "clerk-input",
              footerActionLink: "clerk-link",
            },
          }}
          fallbackRedirectUrl="/admin"
          signUpUrl="/admin/sign-up"
        />
      </div>

      <a href="/" class="back-link">← Voltar para o site</a>
    </div>
  </div>
</Layout>

<style>
  .login-page {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem;
    background: linear-gradient(135deg, #8414e3 0%, #c51be4 100%);
  }

  .login-container {
    width: 100%;
    max-width: 400px;
  }

  .login-brand {
    text-align: center;
    margin-bottom: 2rem;
  }

  .login-logo-img {
    width: 80px;
    height: 80px;
    object-fit: contain;
    margin-bottom: 1rem;
    background: white;
    border-radius: 16px;
    padding: 0.5rem;
  }

  .login-brand h1 {
    font-size: 1.75rem;
    font-weight: 800;
    color: white;
    margin-bottom: 0.25rem;
  }

  .login-brand p {
    font-size: 0.875rem;
    color: rgba(255, 255, 255, 0.8);
  }

  .clerk-login {
    background: white;
    border-radius: 16px;
    padding: 2rem;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.2);
  }

  .back-link {
    display: block;
    text-align: center;
    margin-top: 1.5rem;
    color: white;
    text-decoration: none;
    font-size: 0.875rem;
    opacity: 0.9;
  }

  .back-link:hover {
    opacity: 1;
  }

  @media (max-width: 480px) {
    .login-page {
      padding: 1rem;
    }
    .clerk-login {
      padding: 1.5rem;
    }
    .login-logo-img {
      width: 60px;
      height: 60px;
    }
  }

  :global(.clerk-card) {
    box-shadow: none !important;
    border: none !important;
    width: 100% !important;
  }

  :global(.clerk-root) {
    width: 100%;
  }

  :global(.clerk-button-primary) {
    background: #8414e3 !important;
    width: 100%;
  }

  :global(.clerk-button-primary:hover) {
    background: #7c3aed !important;
  }

  :global(.clerk-input) {
    width: 100%;
    padding: 0.75rem;
    border: 1px solid #e5e7eb;
    border-radius: 8px;
    font-size: 1rem;
  }

  :global(.clerk-input:focus) {
    outline: none;
    border-color: #8414e3;
    box-shadow: 0 0 0 3px rgba(132, 20, 227, 0.1);
  }

  :global(.clerk-link) {
    color: #8414e3;
  }
</style>
