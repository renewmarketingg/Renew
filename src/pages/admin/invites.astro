---
import Layout from "../../layouts/Layout.astro";
import { Icon } from "astro-icon/components";
import PageHeader from "../../components/page-header/page-header.astro";
import Button from "../../components/button/button.astro";
import "../../styles/global.css";
---

<Layout title="Gerenciar Convites" adm={true} activePage="/admin/invites">
  <div class="admin-content">
    <PageHeader title="Gerenciar Convites">
      <Button id="generateBtn" variant="primary">
        <Icon name="lucide:plus" size={18} />Novo Convite
      </Button>
    </PageHeader>

    <div class="card">
      <div class="card-header">
        <h3><Icon name="lucide:users" size={20} /> Convites</h3>
      </div>
      <div class="card-body">
        <div id="invitesList"></div>
      </div>
    </div>

    <div class="card" style="margin-top: 1.5rem;">
      <div class="card-header">
        <h3><Icon name="lucide:link" size={20} /> Gerar Novo Convite</h3>
      </div>
      <div class="card-body">
        <div class="form-group">
          <label for="inviteEmail">Email para convite</label>
          <input type="email" id="inviteEmail" placeholder="email@exemplo.com" />
        </div>
        <Button id="createInviteBtn" variant="primary">
          <Icon name="lucide:send" size={18} />Gerar Link
        </Button>
        <div id="inviteLink" class="invite-link-box" style="display: none;">
          <p>Compartilhe este link:</p>
          <code id="linkText"></code>
          <Button id="copyBtn" variant="secondary" size="sm">
            <Icon name="lucide:copy" size={16} />Copiar
          </Button>
        </div>
      </div>
    </div>
  </div>
</Layout>

<script>
  interface Invite {
    id: string;
    token: string;
    email: string;
    createdAt: string;
    used: boolean;
    usedBy?: string;
    usedAt?: string;
  }

  const INVITES_KEY = 'admin_invites';

  function generateToken(): string {
    return 'inv_' + Math.random().toString(36).substring(2, 15) + Date.now().toString(36);
  }

  function getInvites(): Invite[] {
    return JSON.parse(localStorage.getItem(INVITES_KEY) || '[]');
  }

  function saveInvites(invites: Invite[]): void {
    localStorage.setItem(INVITES_KEY, JSON.stringify(invites));
  }

  function createInvite(email: string): Invite {
    const invites = getInvites();
    const invite: Invite = {
      id: 'inv_' + Date.now(),
      token: generateToken(),
      email: email || 'Qualquer email',
      createdAt: new Date().toISOString(),
      used: false,
    };
    invites.unshift(invite);
    saveInvites(invites);
    return invite;
  }

  function deleteInvite(id: string): void {
    let invites = getInvites();
    invites = invites.filter((inv: Invite) => inv.id !== id);
    saveInvites(invites);
    render();
  }

  function copyLink(token: string): void {
    const url = `${window.location.origin}/admin/register?token=${token}`;
    navigator.clipboard.writeText(url);
    showToast('Link copiado!', 'success');
  }

  function formatDate(isoString: string): string {
    return new Date(isoString).toLocaleString('pt-BR', {
      day: '2-digit',
      month: '2-digit',
      year: 'numeric',
      hour: '2-digit',
      minute: '2-digit',
    });
  }

  function render(): void {
    const invites = getInvites();
    const list = document.getElementById('invitesList');
    
    if (!list) return;
    
    if (invites.length === 0) {
      list.innerHTML = '<p style="color: #747474; text-align: center; padding: 2rem;">Nenhum convite ainda</p>';
      return;
    }

    list.innerHTML = `
      <table class="table">
        <thead>
          <tr>
            <th>Email</th>
            <th>Token</th>
            <th>Criado</th>
            <th>Status</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          ${invites.map((inv: Invite) => `
            <tr>
              <td>${inv.email}</td>
              <td><code style="font-size: 0.75rem;">${inv.token.substring(0, 12)}...</code></td>
              <td>${formatDate(inv.createdAt)}</td>
              <td>
                <span class="badge ${inv.used ? 'badge-used' : 'badge-active'}">
                  ${inv.used ? 'Usado' : 'Pendente'}
                </span>
              </td>
              <td>
                <div class="flex gap-1">
                  <button class="action-btn copy-link-btn" data-token="${inv.token}" title="Copiar link">
                    <Icon name="lucide:copy" size={16} />
                  </button>
                  <button class="action-btn delete-invite-btn" data-id="${inv.id}" title="Excluir">
                    <Icon name="lucide:trash-2" size={16} />
                  </button>
                </div>
              </td>
            </tr>
          `).join('')}
        </tbody>
      </table>
    `;

    document.querySelectorAll<HTMLButtonElement>('.copy-link-btn').forEach((btn) => {
      btn.addEventListener('click', () => copyLink(btn.dataset.token || ''));
    });

    document.querySelectorAll<HTMLButtonElement>('.delete-invite-btn').forEach((btn) => {
      btn.addEventListener('click', () => deleteInvite(btn.dataset.id || ''));
    });
  }

  function showToast(message: string, type: string = 'info'): void {
    const toast = document.createElement('div');
    toast.className = `toast toast-${type}`;
    toast.textContent = message;
    document.body.appendChild(toast);
    setTimeout(() => toast.classList.add('show'), 10);
    setTimeout(() => {
      toast.classList.remove('show');
      setTimeout(() => toast.remove(), 300);
    }, 3000);
  }

  document.getElementById('createInviteBtn')?.addEventListener('click', () => {
    const emailInput = document.getElementById('inviteEmail') as HTMLInputElement | null;
    const email = emailInput?.value || '';
    const invite = createInvite(email);
    const link = `${window.location.origin}/admin/register?token=${invite.token}`;
    
    const linkText = document.getElementById('linkText');
    const inviteLink = document.getElementById('inviteLink');
    
    if (linkText) linkText.textContent = link;
    if (inviteLink) inviteLink.style.display = 'block';
    if (emailInput) emailInput.value = '';
    
    render();
    showToast('Convite criado!', 'success');
  });

  document.getElementById('copyBtn')?.addEventListener('click', () => {
    const linkText = document.getElementById('linkText');
    if (linkText?.textContent) {
      navigator.clipboard.writeText(linkText.textContent);
      showToast('Link copiado!', 'success');
    }
  });

  render();
</script>

<style>
  .invite-link-box {
    margin-top: 1rem;
    padding: 1rem;
    background: #f3f4f6;
    border-radius: 8px;
  }

  .invite-link-box p {
    margin: 0 0 0.5rem;
    font-size: 0.875rem;
    color: #747474;
  }

  .invite-link-box code {
    display: block;
    padding: 0.5rem;
    background: white;
    border-radius: 4px;
    font-size: 0.75rem;
    word-break: break-all;
    margin-bottom: 0.75rem;
  }

  .badge-used {
    background: #fef3c7;
    color: #d97706;
  }

  :global(.toast) {
    position: fixed;
    bottom: 2rem;
    right: 2rem;
    padding: 1rem 1.5rem;
    border-radius: 8px;
    font-size: 0.875rem;
    font-weight: 500;
    z-index: 1000;
    opacity: 0;
    transform: translateY(1rem);
    transition: all 0.3s;
  }

  :global(.toast.show) {
    opacity: 1;
    transform: translateY(0);
  }

  :global(.toast-success) { background: #22c55e; color: white; }
  :global(.toast-error) { background: #ef4444; color: white; }
  :global(.toast-info) { background: #8414e3; color: white; }
</style>
