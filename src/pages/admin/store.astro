---
import Layout from '@/layouts/Layout.astro';
import { Icon } from 'astro-icon/components';
import '@/styles/global.css';
import AdminFilters from '@/components/ui/AdminFilters/AdminFilters.astro';
import AdminStatsGrid from '@/components/ui/AdminStatsGrid/AdminStatsGrid.astro';
import Button from '@/components/ui/Button/Button.astro';
import PageHeader from '@/components/PageHeader/PageHeader.astro';
import AdminModal from '@/components/ui/AdminModal/AdminModal.astro';

const productCategories = ['Todos', 'Eletrônicos', 'Áudio', 'Acessórios', 'Games', 'Livros'];

const stats = [
  { label: 'Total', value: '0', statKey: 'total', icon: 'lucide:package' },
  { label: 'Destaques', value: '0', statKey: 'featured', icon: 'lucide:star' },
  { label: 'Valor Médio', value: 'R$ 0', statKey: 'avg', icon: 'lucide:tag' },
  { label: 'Categorias', value: '0', statKey: 'categories', icon: 'lucide:folder' },
];

const filters = [
  {
    id: 'isTest',
    label: 'Produtos de teste',
    type: 'checkbox' as const,
  },
  {
    id: 'category',
    label: 'Categoria',
    type: 'select' as const,
    options: productCategories.map((c) => ({ value: c, label: c })),
  },
  {
    id: 'featured',
    label: 'Status',
    type: 'select' as const,
    options: [
      { value: 'true', label: 'Destaque' },
      { value: 'false', label: 'Ativo' },
    ],
  },
];
---

<Layout title="Gerenciar Produtos" adm={true} activePage="/admin/store">
  <div class="admin-content">
    <PageHeader title="Gerenciar Produtos">
      <Button id="addBtn" variant="primary">
        <Icon name="lucide:plus" size={18} />Novo
      </Button>
    </PageHeader>

    <AdminStatsGrid {stats} />

    <AdminFilters searchPlaceholder="Buscar produtos..." {filters} />

    <div class="table-wrapper">
      <table class="table">
        <thead>
          <tr>
            <th>Produto</th>
            <th>Categoria</th>
            <th>Preço</th>
            <th>Status</th>
            <th></th>
          </tr>
        </thead>
        <tbody id="tableBody"></tbody>
      </table>
    </div>
  </div>

  <AdminModal id="itemModal" title="Novo">
    <form id="itemForm">
      <input type="hidden" id="itemId" />
      <div class="form-group">
        <label for="name">Nome</label>
        <input type="text" id="name" required />
      </div>
      <div class="form-group">
        <label for="description">Descrição</label>
        <textarea id="description" rows="2" required></textarea>
      </div>
      <div class="form-row">
        <div class="form-group">
          <label for="price">Preço</label>
          <input type="number" id="price" step="0.01" required />
        </div>
        <div class="form-group">
          <label for="originalPrice">Original</label>
          <input type="number" id="originalPrice" step="0.01" />
        </div>
      </div>
      <div class="form-row">
        <div class="form-group">
          <label for="category">Categoria</label>
          <select id="category" required>
            {productCategories.map((cat) => <option value={cat}>{cat}</option>)}
          </select>
        </div>
        <div class="form-group">
          <label for="rating">Avaliação</label>
          <input type="number" id="rating" min="0" max="5" step="0.1" value="4.5" />
        </div>
      </div>
      <div class="form-group">
        <label for="image">Imagem</label>
        <input type="url" id="image" required />
      </div>
      <div class="form-group">
        <label for="affiliateLink">Link</label>
        <input type="url" id="affiliateLink" required />
      </div>
      <div class="form-group">
        <div class="checkbox-group">
          <input type="checkbox" id="featured" />
          <label for="featured">Destaque</label>
        </div>
      </div>
    </form>
    <div slot="footer">
      <Button id="cancelBtn" variant="secondary">Cancelar</Button>
      <Button id="saveBtn" variant="primary">Salvar</Button>
    </div>
  </AdminModal>

  <AdminModal id="deleteModal" title="Excluir?" size="sm">
    <p>Excluir <strong id="deleteName"></strong>?</p>
    <div slot="footer">
      <Button id="cancelDeleteBtn" variant="secondary">Cancelar</Button>
      <Button id="confirmDeleteBtn" variant="danger">Excluir</Button>
    </div>
  </AdminModal>
</Layout>

<script>
  import { initStore } from '@/lib/store-admin';
  initStore();
</script>
