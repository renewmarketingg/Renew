---
import Layout from '@/layouts/Layout.astro';
import { Icon } from 'astro-icon/components';
---

<Layout title="Documentação - Renew Digital" adm={true} activePage="/admin/docs">
  <div class="docs-layout">
    <aside class="docs-sidebar">
      <nav class="docs-nav">
        <div class="docs-nav-section">
          <h3>Getting Started</h3>
          <ul>
            <li><a href="/admin/docs" class="active">Visão Geral</a></li>
            <li><a href="/admin/docs/structure">Estrutura</a></li>
          </ul>
        </div>
        <div class="docs-nav-section">
          <h3>Sistema</h3>
          <ul>
            <li><a href="/admin/docs/auth">Autenticação</a></li>
            <li><a href="/admin/docs/store">Loja e Carrinho</a></li>
            <li><a href="/admin/docs/ai">Inteligencia Artificial</a></li>
          </ul>
        </div>
        <div class="docs-nav-section">
          <h3>Backend</h3>
          <ul>
            <li><a href="/admin/docs/database">Banco de Dados</a></li>
            <li><a href="/admin/docs/api">APIs</a></li>
          </ul>
        </div>
        <div class="docs-nav-section">
          <h3>Configuracao</h3>
          <ul>
            <li><a href="/admin/docs/env">Variaveis de Ambiente</a></li>
            <li><a href="/admin/docs/commands">Comandos</a></li>
          </ul>
        </div>
      </nav>
    </aside>

    <main class="docs-content">
      <h1>Documentacao do Projeto Renew Digital</h1>
      <p class="lead">
        Documentacao completa do sistema Renew Digital - agencia de servicos digitais com loja
        integrada, chat com IA e painel administrativo completo.
      </p>

      <h2><Icon name="lucide:sparkles" size={20} /> Funcionalidades Principais</h2>
      <div class="features-grid">
        <div class="feature-card">
          <Icon name="lucide:shopping-bag" size={32} />
          <h3>Loja Integrada</h3>
          <p>Catalogo de produtos com carrinho client-side</p>
        </div>
        <div class="feature-card">
          <Icon name="lucide:bot" size={32} />
          <h3>Chat com IA</h3>
          <p>Assistente com suporte a multiplos provedores</p>
        </div>
        <div class="feature-card">
          <Icon name="lucide:shield-check" size={32} />
          <h3>Painel Admin</h3>
          <p>Gerenciamento completo de produtos</p>
        </div>
        <div class="feature-card">
          <Icon name="lucide:zap" size={32} />
          <h3>Performance</h3>
          <p>SSR com Astro 5 e deploy na Vercel</p>
        </div>
      </div>

      <h2>Links Rapidos</h2>
      <div class="links-grid">
        <a href="/admin/docs/auth" class="quick-link">
          <Icon name="lucide:lock" size={20} />
          <span>Autenticacao</span>
        </a>
        <a href="/admin/docs/store" class="quick-link">
          <Icon name="lucide:shopping-cart" size={20} />
          <span>Loja e Carrinho</span>
        </a>
        <a href="/admin/docs/ai" class="quick-link">
          <Icon name="lucide:bot" size={20} />
          <span>Inteligencia Artificial</span>
        </a>
        <a href="/admin/docs/api" class="quick-link">
          <Icon name="lucide:webhook" size={20} />
          <span>API Endpoints</span>
        </a>
      </div>
    </main>
  </div>
</Layout>

<style>
  .docs-layout {
    display: flex;
    gap: 2rem;
    max-width: 1400px;
    margin: 70px auto;
    padding: 2rem;
  }

  .docs-sidebar {
    width: 260px;
    flex-shrink: 0;
    position: sticky;
    top: 90px;
    height: fit-content;
    max-height: calc(100vh - 110px);
    overflow-y: auto;
  }

  .docs-nav {
    background: var(--color-white);
    border-radius: var(--border-radius-lg);
    border: 1px solid var(--color-gray-200);
    padding: 1rem;
  }

  .docs-nav-section {
    margin-bottom: 1.5rem;
  }

  .docs-nav-section:last-child {
    margin-bottom: 0;
  }

  .docs-nav-section h3 {
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    color: var(--color-primary);
    margin-bottom: 0.5rem;
    padding-left: 0.75rem;
  }

  .docs-nav-section ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .docs-nav-section a {
    display: block;
    padding: 0.5rem 0.75rem;
    color: var(--color-gray-400);
    text-decoration: none;
    font-size: 0.875rem;
    border-radius: var(--border-radius-sm);
    transition: all var(--transition-fast);
  }

  .docs-nav-section a:hover {
    background: var(--color-primary-alpha-10);
    color: var(--color-dark);
  }

  .docs-nav-section a.active {
    background: var(--color-primary-alpha-20);
    color: var(--color-primary);
    font-weight: 600;
  }

  .docs-content {
    flex: 1;
    min-width: 0;
    background: var(--color-white);
    border-radius: var(--border-radius-lg);
    border: 1px solid var(--color-gray-200);
    padding: 2rem;
  }

  .docs-content h1 {
    font-size: 2rem;
    font-weight: 800;
    color: var(--color-dark);
    margin-bottom: 1rem;
  }

  .docs-content h2 {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--color-dark);
    margin: 2rem 0 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 2px solid var(--color-primary-alpha-20);
  }

  .docs-content h2:first-of-type {
    margin-top: 0;
  }

  .docs-content h2 svg {
    color: var(--color-primary);
  }

  .docs-content .lead {
    font-size: 1.125rem;
    color: var(--color-gray-400);
    line-height: 1.7;
    margin-bottom: 2rem;
  }

  .features-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
    margin: 1rem 0 2rem;
  }

  .feature-card {
    background: var(--color-gray-50);
    padding: 1.5rem;
    border-radius: var(--border-radius-md);
    border: 1px solid var(--color-gray-200);
  }

  .feature-card svg {
    color: var(--color-primary);
    margin-bottom: 0.75rem;
  }

  .feature-card h3 {
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-dark);
    margin-bottom: 0.5rem;
  }

  .feature-card p {
    font-size: 0.875rem;
    color: var(--color-gray-400);
    margin: 0;
  }

  .links-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1rem;
  }

  .quick-link {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 1rem;
    background: var(--color-gray-50);
    border: 1px solid var(--color-gray-200);
    border-radius: var(--border-radius-md);
    text-decoration: none;
    color: var(--color-dark);
    font-weight: 500;
    transition: all var(--transition-fast);
  }

  .quick-link:hover {
    background: var(--color-primary);
    border-color: var(--color-primary);
    color: white;
  }

  .quick-link svg {
    color: var(--color-primary);
  }

  .quick-link:hover svg {
    color: white;
  }

  @media (max-width: 992px) {
    .docs-layout {
      flex-direction: column;
    }

    .docs-sidebar {
      width: 100%;
      position: static;
      max-height: none;
    }

    .docs-nav {
      display: flex;
      flex-wrap: wrap;
      gap: 1rem;
    }

    .docs-nav-section {
      margin-bottom: 0;
    }

    .features-grid,
    .links-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 768px) {
    .docs-layout {
      padding: 1rem;
      margin-top: 80px;
    }

    .docs-content {
      padding: 1.5rem;
    }

    .features-grid,
    .links-grid {
      grid-template-columns: 1fr;
    }
  }

  :global([data-theme='dark']) .docs-nav,
  :global([data-theme='dark']) .docs-content {
    background: #1e1e1e;
    border-color: #333;
  }

  :global([data-theme='dark']) .docs-content h1,
  :global([data-theme='dark']) .docs-content h2 {
    color: #e5e5e5;
  }

  :global([data-theme='dark']) .docs-content .lead {
    color: #a0a0a0;
  }

  :global([data-theme='dark']) .feature-card,
  :global([data-theme='dark']) .quick-link {
    background: #252525;
    border-color: #333;
  }

  :global([data-theme='dark']) .feature-card h3,
  :global([data-theme='dark']) .quick-link {
    color: #e5e5e5;
  }

  :global([data-theme='dark']) .feature-card p {
    color: #a0a0a0;
  }
</style>
