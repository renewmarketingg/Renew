---
import Layout from '@/layouts/Layout.astro';
import { Icon } from 'astro-icon/components';
---

<Layout title="Inteligencia Artificial - Documentacao" adm={true} activePage="/admin/docs">
  <div class="docs-layout">
    <aside class="docs-sidebar">
      <nav class="docs-nav">
        <div class="docs-nav-section">
          <h3>Getting Started</h3>
          <ul>
            <li><a href="/admin/docs">Visao Geral</a></li>
            <li><a href="/admin/docs/structure">Estrutura</a></li>
          </ul>
        </div>
        <div class="docs-nav-section">
          <h3>Sistema</h3>
          <ul>
            <li><a href="/admin/docs/auth">Autenticacao</a></li>
            <li><a href="/admin/docs/store">Loja e Carrinho</a></li>
            <li><a href="/admin/docs/ai" class="active">Inteligencia Artificial</a></li>
          </ul>
        </div>
        <div class="docs-nav-section">
          <h3>Backend</h3>
          <ul>
            <li><a href="/admin/docs/database">Banco de Dados</a></li>
            <li><a href="/admin/docs/api">APIs</a></li>
          </ul>
        </div>
        <div class="docs-nav-section">
          <h3>Configuracao</h3>
          <ul>
            <li><a href="/admin/docs/env">Variaveis de Ambiente</a></li>
            <li><a href="/admin/docs/commands">Comandos</a></li>
          </ul>
        </div>
      </nav>
    </aside>

    <main class="docs-content">
      <h1><Icon name="lucide:brain" size={24} /> Modulo de Inteligencia Artificial</h1>
      <p class="lead">
        O projeto integra multiplos provedores de IA usando o <strong>Vercel AI SDK</strong>,
        permitindo chat em tempo tempo real com modelos de linguagem avanados.
      </p>

      <h2><Icon name="lucide:server" size={20} /> Provedores Suportados</h2>
      <div class="providers-grid">
        <div class="provider-card">
          <strong>OpenAI</strong>
          <span>gpt-4o, gpt-4o-mini, gpt-4-turbo</span>
        </div>
        <div class="provider-card">
          <strong>Anthropic</strong>
          <span>claude-3-5-sonnet, claude-3-5-haiku</span>
        </div>
        <div class="provider-card">
          <strong>Google</strong>
          <span>gemini-1.5-pro, gemini-1.5-flash</span>
        </div>
        <div class="provider-card">
          <strong>Mistral</strong>
          <span>mistral-large, mistral-small</span>
        </div>
        <div class="provider-card">
          <strong>Groq</strong>
          <span>llama-3.1-70b, mixtral-8x7b</span>
        </div>
        <div class="provider-card">
          <strong>Cohere</strong>
          <span>command-r-plus, command-r</span>
        </div>
      </div>

      <h2><Icon name="lucide:folder-tree" size={20} /> Estrutura de Arquivos</h2>
      <div class="files-list">
        <div class="file-item">
          <Icon name="lucide:file-code" size={16} />
          <code>src/lib/ai/index.ts</code>
          <span>Inicializacao principal</span>
        </div>
        <div class="file-item">
          <Icon name="lucide:file-code" size={16} />
          <code>src/lib/ai/chat.ts</code>
          <span>Gerenciamento de chat</span>
        </div>
        <div class="file-item">
          <Icon name="lucide:file-code" size={16} />
          <code>src/lib/ai/chat-service.ts</code>
          <span>Integracao com API de IA</span>
        </div>
        <div class="file-item">
          <Icon name="lucide:file-code" size={16} />
          <code>src/lib/ai/models.ts</code>
          <span>Configuracoes de modelos</span>
        </div>
        <div class="file-item">
          <Icon name="lucide:file-code" size={16} />
          <code>src/lib/ai/providers.ts</code>
          <span>Fabrica de provedores</span>
        </div>
        <div class="file-item">
          <Icon name="lucide:file-code" size={16} />
          <code>src/lib/ai/settings.ts</code>
          <span>Preferencias do usuario</span>
        </div>
        <div class="file-item">
          <Icon name="lucide:file-code" size={16} />
          <code>src/lib/ai/storage.ts</code>
          <span>Persistencia em localStorage</span>
        </div>
        <div class="file-item">
          <Icon name="lucide:file-code" size={16} />
          <code>src/lib/ai/theme.ts</code>
          <span>Alternancia de tema</span>
        </div>
        <div class="file-item">
          <Icon name="lucide:file-code" size={16} />
          <code>src/lib/ai/ui.ts</code>
          <span>Helpers de renderizacao</span>
        </div>
        <div class="file-item">
          <Icon name="lucide:file-code" size={16} />
          <code>src/lib/ai/projects.ts</code>
          <span>Conection de projetos</span>
        </div>
      </div>

      <h2><Icon name="lucide:key" size={20} /> Variaveis de Ambiente</h2>
      <p>Configure a chave API do provedor desejado:</p>
      <pre>OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GEMINI_API_KEY=AIza...
MISTRAL_API_KEY=...
GROQ_API_KEY=gsk_...
COHERE_API_KEY=...</pre>

      <h2><Icon name="lucide:code" size={20} /> Uso Basico</h2>
      <pre>import {'{'} sendMessage {'}'} from './lib/ai/chat-service';

const response = await sendMessage({'{'}
  messages: [{'{'} role: 'user', content: 'Hello!' {'}'}],
  model: 'gpt-4o',
  temperature: 0.7,
  maxTokens: 4096,
{'}'});</pre>

      <h2><Icon name="lucide:sliders" size={20} /> Configuracoes de Modelo</h2>
      <p>Cada modelo possui configuracoes otimizadas:</p>
      <ul class="feature-list">
        <li><strong>temperature:</strong> Controla a aleatoriedade das respostas (0-2)</li>
        <li><strong>maxTokens:</strong> Limite maximo de tokens na resposta</li>
        <li><strong>topP:</strong> Nucleus sampling para diversidade</li>
        <li><strong>presencePenalty:</strong> Penalidade para repeticao de topicos</li>
        <li><strong>frequencyPenalty:</strong> Penalidade para repeticao de palavras</li>
      </ul>

      <h2><Icon name="lucide:palette" size={20} /> Temas</h2>
      <p>O modulo AI suporta temas claros e escuros com UI adaptativa:</p>
      <pre>import {'{'} toggleTheme, getCurrentTheme {'}'} from './lib/ai/theme';

toggleTheme(); // Alterna entre light/dark
const theme = getCurrentTheme(); // Retorna 'light' | 'dark'</pre>
    </main>
  </div>
</Layout>

<style>
  .docs-layout {
    display: flex;
    gap: 2rem;
    max-width: 1400px;
    margin: 70px auto;
    padding: 2rem;
  }

  .docs-sidebar {
    width: 260px;
    flex-shrink: 0;
    position: sticky;
    top: 90px;
    height: fit-content;
    max-height: calc(100vh - 110px);
    overflow-y: auto;
  }

  .docs-nav {
    background: var(--color-white);
    border-radius: var(--border-radius-lg);
    border: 1px solid var(--color-gray-200);
    padding: 1rem;
  }

  .docs-nav-section {
    margin-bottom: 1.5rem;
  }

  .docs-nav-section h3 {
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    color: var(--color-primary);
    margin-bottom: 0.5rem;
    padding-left: 0.75rem;
  }

  .docs-nav-section ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .docs-nav-section a {
    display: block;
    padding: 0.5rem 0.75rem;
    color: var(--color-gray-400);
    text-decoration: none;
    font-size: 0.875rem;
    border-radius: var(--border-radius-sm);
    transition: all var(--transition-fast);
  }

  .docs-nav-section a:hover {
    background: var(--color-primary-alpha-10);
    color: var(--color-dark);
  }

  .docs-nav-section a.active {
    background: var(--color-primary-alpha-20);
    color: var(--color-primary);
    font-weight: 600;
  }

  .docs-content {
    flex: 1;
    background: var(--color-white);
    border-radius: var(--border-radius-lg);
    border: 1px solid var(--color-gray-200);
    padding: 2rem;
  }

  .docs-content h1 {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 2rem;
    font-weight: 800;
    color: var(--color-dark);
    margin-bottom: 1rem;
  }

  .docs-content h1 svg {
    color: var(--color-primary);
  }

  .docs-content h2 {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--color-dark);
    margin: 2rem 0 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 2px solid var(--color-primary-alpha-20);
  }

  .docs-content h2:first-of-type {
    margin-top: 0;
  }

  .docs-content h2 svg {
    color: var(--color-primary);
  }

  .docs-content .lead {
    font-size: 1.125rem;
    color: var(--color-gray-400);
    line-height: 1.7;
  }

  .docs-content p {
    color: var(--color-gray-400);
    line-height: 1.7;
    margin-bottom: 1rem;
  }

  .docs-content code {
    font-family: monospace;
    background: var(--color-primary-alpha-10);
    color: var(--color-primary);
    padding: 0.2em 0.4em;
    border-radius: 4px;
  }

  .docs-content pre {
    background: var(--color-gray-900);
    color: #f8f8f2;
    padding: 1rem;
    border-radius: var(--border-radius-md);
    overflow-x: auto;
    margin: 1rem 0;
    font-size: 0.875rem;
    line-height: 1.6;
  }

  .docs-content ul {
    color: var(--color-gray-400);
    padding-left: 1.5rem;
    margin-bottom: 1rem;
  }

  .docs-content li {
    margin-bottom: 0.5rem;
  }

  .providers-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 1rem;
    margin: 1rem 0;
  }

  .provider-card {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    padding: 1rem;
    background: var(--color-gray-50);
    border-radius: var(--border-radius-md);
    border: 1px solid var(--color-gray-200);
  }

  .provider-card strong {
    color: var(--color-dark);
  }

  .provider-card span {
    font-size: 0.75rem;
    color: var(--color-gray-400);
    font-family: monospace;
  }

  .feature-list {
    list-style: none;
    padding: 0;
  }

  .feature-list li {
    padding: 0.75rem 0;
    padding-left: 1.5rem;
    position: relative;
    border-bottom: 1px solid var(--color-gray-100);
  }

  .feature-list li::before {
    content: '->';
    position: absolute;
    left: 0;
    color: var(--color-primary);
  }

  .files-list {
    display: grid;
    gap: 0.75rem;
  }

  .file-item {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.875rem;
    background: var(--color-gray-50);
    border-radius: var(--border-radius-md);
    border: 1px solid var(--color-gray-200);
  }

  .file-item svg {
    color: var(--color-primary);
  }

  .file-item code {
    font-size: 0.875rem;
    color: var(--color-dark);
    background: none;
    padding: 0;
  }

  .file-item span {
    margin-left: auto;
    font-size: 0.75rem;
    color: var(--color-gray-400);
  }

  @media (max-width: 992px) {
    .docs-layout {
      flex-direction: column;
    }

    .docs-sidebar {
      width: 100%;
      position: static;
    }

    .docs-nav {
      display: flex;
      flex-wrap: wrap;
      gap: 1rem;
    }
  }

  :global([data-theme='dark']) .docs-nav,
  :global([data-theme='dark']) .docs-content {
    background: #1e1e1e;
    border-color: #333;
  }

  :global([data-theme='dark']) .docs-content h1,
  :global([data-theme='dark']) .docs-content h2,
  :global([data-theme='dark']) .docs-content h3 {
    color: #e5e5e5;
  }

  :global([data-theme='dark']) .docs-content p,
  :global([data-theme='dark']) .docs-content li {
    color: #a0a0a0;
  }

  :global([data-theme='dark']) .file-item {
    background: #252525;
    border-color: #333;
  }

  :global([data-theme='dark']) .file-item code {
    color: #e5e5e5;
  }

  :global([data-theme='dark']) .provider-card {
    background: #252525;
    border-color: #333;
  }

  :global([data-theme='dark']) .provider-card strong {
    color: #e5e5e5;
  }
</style>
